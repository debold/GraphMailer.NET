# Normalize line endings: LF in the repository, native on checkout.
* text=auto

# Windows-only files always check out with CRLF.
*.ps1  text eol=crlf
*.cmd  text eol=crlf
*.bat  text eol=crlf
*.sln  text eol=crlf

# Binary assets — never touch.
*.ico  binary
*.png  binary
*.jpg  binary
*.snk  binary
*.pfx  binary
