<UserControl x:Class="GraphMailer.ConfigTool.Views.NotificationsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:GraphMailer.ConfigTool.Helpers"
             Background="{StaticResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24,20,24,24">

            <!-- Notification settings card -->
            <Border Style="{StaticResource Card}"
                    Margin="0,0,0,16">
                <StackPanel>
                    <Border Style="{StaticResource CardHeader}">
                        <TextBlock Text="Notification Settings"
                                   Style="{StaticResource SectionHeader}"/>
                    </Border>
                    <Grid Margin="16,12,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Sender email address"
                                   Style="{StaticResource LabelText}"
                                   Margin="0,0,0,4"/>
                        <TextBox    Grid.Row="0"
                                    Grid.Column="2"
                                    x:Name="NotifFrom"
                                    ToolTip="The From address used when sending admin notification emails.&#x0a;Must be a mailbox that the configured Graph API service principal has Mail.Send permission for."
                                    TextChanged="EmailField_Changed"/>
                        <TextBlock Grid.Row="1"
                                   Grid.Column="2"
                                   x:Name="SenderError"
                                   Foreground="{StaticResource DangerBrush}" FontSize="12"
                                   Margin="0,6,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>

                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Text="Subject prefix"
                                   Style="{StaticResource LabelText}"
                                   Margin="0,0,0,4"/>
                        <TextBox    Grid.Row="3"
                                    Grid.Column="2"
                                    x:Name="SubjectPrefix"
                                    Text="[GraphMailer]"
                                    ToolTip="Prefix prepended to the subject line of every admin notification email.&#x0a;Useful for email rules and filtering. Example: [GraphMailer] Certificate expiring soon."
                                    TextChanged="AnyField_Changed"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Non-Delivery Report card -->
            <Border Style="{StaticResource Card}"
                    Margin="0,0,0,16">
                <StackPanel>
                    <Border Style="{StaticResource CardHeader}">
                        <StackPanel>
                            <TextBlock Text="Non-Delivery Reports (NDR)"
                                       Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="When a message is accepted by SMTP but permanently rejected by Microsoft 365, GraphMailer can send a bounce notification to the original sender and/or the admin. Uses the sender address configured in Notification Settings."
                                       Style="{StaticResource HintText}"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <StackPanel Margin="16,12,16,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                            </Grid.RowDefinitions>

                            <CheckBox Grid.Row="0"
                                      Grid.Column="0"
                                      Style="{StaticResource ToggleSwitch}"
                                      x:Name="NdrEnabled"
                                      IsChecked="False"
                                      Checked="AnyCheckbox_Changed"
                                      Unchecked="AnyCheckbox_Changed"/>
                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Text="Enable Non-Delivery Reports"
                                       Style="{StaticResource BodyText}"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"/>

                            <CheckBox Grid.Row="1"
                                      Grid.Column="0"
                                      Style="{StaticResource ToggleSwitch}"
                                      x:Name="NdrNotifySender"
                                      IsChecked="True"
                                      Checked="AnyCheckbox_Changed"
                                      Unchecked="AnyCheckbox_Changed"/>
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="Send NDR to original sender"
                                       Style="{StaticResource BodyText}"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"/>

                            <CheckBox Grid.Row="2"
                                      Grid.Column="0"
                                      Style="{StaticResource ToggleSwitch}"
                                      x:Name="NdrNotifyAdmin"
                                      IsChecked="False"
                                      Checked="AnyCheckbox_Changed"
                                      Unchecked="AnyCheckbox_Changed"/>
                            <StackPanel Grid.Row="2"
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Send NDR copy to admin recipients"
                                           Style="{StaticResource BodyText}"
                                           VerticalAlignment="Center"/>
                                <!-- Explains the greyed-out switch when no recipient exists yet -->
                                <TextBlock x:Name="NdrNotifyAdminHint"
                                           Text="— add an admin recipient below first"
                                           Style="{StaticResource HintText}"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Master switch: turns every admin notification off in one place, so the sender
                 address and the recipient list can be kept without anything being sent. -->
            <!-- Admin recipients card. Deliberately NOT greyed out by the master switch: NDR admin
                 copies and the periodic report use the same list and are independent of it. -->
            <Border Style="{StaticResource Card}"
                    Margin="0,0,0,16">
                <StackPanel>
                    <Border Style="{StaticResource CardHeader}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Admin Recipients"
                                           Style="{StaticResource SectionHeader}"/>
                                <TextBlock Text="Email addresses that receive all system notification emails."
                                           Style="{StaticResource HintText}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="+ Add"
                                    Style="{StaticResource SmallPrimaryButton}"
                                    Click="AddRecipient_Click"/>
                        </Grid>
                    </Border>
                    <DataGrid x:Name="RecipientsGrid"
                              Margin="0"
                              MinHeight="40"
                              MaxHeight="240"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Email Address"
                                                Binding="{Binding Pattern}"
                                                Width="*"/>
                            <DataGridTemplateColumn Header=""
                                                    Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center">
                                            <Button Content="&#x270E;"
                                                    Style="{StaticResource SmallButton}"
                                                    Padding="6,2"
                                                    Height="22"
                                                    Margin="0,0,4,0"
                                                    Click="EditRecipient_Click"/>
                                            <Button Content="&#x2715;"
                                                    Style="{StaticResource SmallDangerButton}"
                                                    Padding="6,2"
                                                    Height="22"
                                                    Click="RemoveRecipient_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Master switch, directly above the event toggles it governs -->
            <Border Style="{StaticResource Card}"
                    Margin="0,0,0,16">
                <StackPanel>
                    <Border Style="{StaticResource CardHeader}">
                        <StackPanel>
                            <TextBlock Text="Admin Notifications"
                                       Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="Master switch for the event alerts below. Turn it off to stop every admin alert at once without losing the recipient list, the sender address or the individual event settings — they are kept and take effect again when you switch it back on. Non-delivery reports and the periodic report have their own switches and keep sending; the recipient list stays editable because they use it too."
                                       Style="{StaticResource HintText}"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Grid Margin="16,12,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0"
                                  Style="{StaticResource ToggleSwitch}"
                                  x:Name="NotifEnabled"
                                  Checked="NotifEnabled_Changed"
                                  Unchecked="NotifEnabled_Changed"/>
                        <TextBlock Grid.Column="1"
                                   Text="Send admin notifications"
                                   Style="{StaticResource BodyText}"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Event toggles card -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <Border Style="{StaticResource CardHeader}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Notify on Events"
                                       Style="{StaticResource SectionHeader}"
                                       VerticalAlignment="Center"/>
                            <!-- Select-all: reflects "every event is on" and sets them all when
                                 toggled. Follows the master switch's enabled state. -->
                            <TextBlock Grid.Column="1"
                                       x:Name="AllEventsLabel"
                                       Text="All"
                                       Style="{StaticResource HintText}"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <CheckBox Grid.Column="2"
                                      Style="{StaticResource ToggleSwitch}"
                                      x:Name="AllEvents"
                                      ToolTip="Switch every event notification below on or off at once."
                                      VerticalAlignment="Center"
                                      Checked="AllEvents_Changed"
                                      Unchecked="AllEvents_Changed"/>
                        </Grid>
                    </Border>
                    <StackPanel x:Name="EventToggles"
                                Margin="16,12,16,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                            </Grid.RowDefinitions>

                            <CheckBox Grid.Row="0"
                                      Grid.Column="0"
                                      Style="{StaticResource ToggleSwitch}"
                                      x:Name="NotifIpBlocked"
                                      IsChecked="True"
                                      Checked="AnyCheckbox_Changed"
                                      Unchecked="AnyCheckbox_Changed"/>
                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Text="IP address blocked"
                                       Style="{StaticResource BodyText}"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"/>

                            <CheckBox Grid.Row="1"
                                      Grid.Column="0"
                                      Style="{StaticResource ToggleSwitch}"
                                      x:Name="NotifDeliveryFailed"
                                      IsChecked="True"
                                      Checked="AnyCheckbox_Changed"
                                      Unchecked="AnyCheckbox_Changed"/>
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="Email delivery failed (all retries exhausted)"
                                       Style="{StaticResource BodyText}"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"/>

                            <CheckBox Grid.Row="2"
                                      Grid.Column="0"
                                      Style="{StaticResource ToggleSwitch}"
                                      x:Name="NotifCertExpiring"
                                      IsChecked="True"
                                      Checked="AnyCheckbox_Changed"
                                      Unchecked="AnyCheckbox_Changed"/>
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Text="TLS listener certificate expiring within warning threshold"
                                       Style="{StaticResource BodyText}"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"/>

                            <CheckBox Grid.Row="3"
                                      Grid.Column="0"
                                      Style="{StaticResource ToggleSwitch}"
                                      x:Name="NotifCertExpired"
                                      IsChecked="True"
                                      Checked="AnyCheckbox_Changed"
                                      Unchecked="AnyCheckbox_Changed"/>
                            <StackPanel Grid.Row="3"
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="TLS listener certificate expired"
                                           Style="{StaticResource BodyText}"
                                           VerticalAlignment="Center"/>
                                <!-- Both cert alerts are about the SMTP listener certificate, not the
                                     Graph client certificate — see the tooltip and the help page. -->
                                <TextBlock Text="&#x2139;"
                                           Style="{StaticResource HintText}"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center"
                                           ToolTip="These two alerts watch the SMTP listener certificate only.&#x0a;The Graph client certificate used for Entra authentication is a different certificate:&#x0a;if it expires, GraphMailer cannot reach Graph at all and therefore cannot email anything —&#x0a;that case is reported in the log and on the Status page instead."/>
                            </StackPanel>

                            <CheckBox Grid.Row="4"
                                      Grid.Column="0"
                                      Style="{StaticResource ToggleSwitch}"
                                      x:Name="NotifGraphCertExpiring"
                                      IsChecked="True"
                                      Checked="AnyCheckbox_Changed"
                                      Unchecked="AnyCheckbox_Changed"/>
                            <StackPanel Grid.Row="4"
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Graph client certificate expiring (Entra authentication)"
                                           Style="{StaticResource BodyText}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="&#x2139;"
                                           Style="{StaticResource HintText}"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center"
                                           ToolTip="Warns while the certificate is still valid — this is the last warning you get.&#x0a;Once it expires GraphMailer can no longer authenticate against Graph and therefore&#x0a;cannot send any email at all, so there is deliberately no &quot;expired&quot; alert:&#x0a;that case is written to the log and shown in the operations report instead.&#x0a;Only applies when Graph API uses certificate authentication."/>
                            </StackPanel>

                            <CheckBox Grid.Row="5"
                                      Grid.Column="0"
                                      Style="{StaticResource ToggleSwitch}"
                                      x:Name="NotifDiskSpace"
                                      IsChecked="True"
                                      Checked="AnyCheckbox_Changed"
                                      Unchecked="AnyCheckbox_Changed"/>
                            <TextBlock Grid.Row="5"
                                       Grid.Column="1"
                                       Text="Low disk space"
                                       Style="{StaticResource BodyText}"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"/>

                            <CheckBox Grid.Row="6"
                                      Grid.Column="0"
                                      Style="{StaticResource ToggleSwitch}"
                                      x:Name="NotifGraphDown"
                                      IsChecked="True"
                                      Checked="AnyCheckbox_Changed"
                                      Unchecked="AnyCheckbox_Changed"/>
                            <TextBlock Grid.Row="6"
                                       Grid.Column="1"
                                       Text="Graph API unreachable"
                                       Style="{StaticResource BodyText}"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"/>

                            <CheckBox Grid.Row="7"
                                      Grid.Column="0"
                                      Style="{StaticResource ToggleSwitch}"
                                      x:Name="NotifPortDown"
                                      IsChecked="True"
                                      Checked="AnyCheckbox_Changed"
                                      Unchecked="AnyCheckbox_Changed"/>
                            <TextBlock Grid.Row="7"
                                       Grid.Column="1"
                                       Text="SMTP port connectivity failure"
                                       Style="{StaticResource BodyText}"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"/>

                            <CheckBox Grid.Row="8"
                                      Grid.Column="0"
                                      Style="{StaticResource ToggleSwitch}"
                                      x:Name="NotifServiceStartStop"
                                      IsChecked="False"
                                      Checked="AnyCheckbox_Changed"
                                      Unchecked="AnyCheckbox_Changed"/>
                            <TextBlock Grid.Row="8"
                                       Grid.Column="1"
                                       Text="Service started / stopped"
                                       Style="{StaticResource BodyText}"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"/>

                            <CheckBox Grid.Row="9"
                                      Grid.Column="0"
                                      Style="{StaticResource ToggleSwitch}"
                                      x:Name="NotifBackup"
                                      IsChecked="True"
                                      Checked="AnyCheckbox_Changed"
                                      Unchecked="AnyCheckbox_Changed"/>
                            <TextBlock Grid.Row="9"
                                       Grid.Column="1"
                                       Text="Configuration backup result (success / failure)"
                                       Style="{StaticResource BodyText}"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"/>

                            <CheckBox Grid.Row="10"
                                      Grid.Column="0"
                                      Style="{StaticResource ToggleSwitch}"
                                      x:Name="NotifUpdateAvailable"
                                      IsChecked="False"
                                      Checked="AnyCheckbox_Changed"
                                      Unchecked="AnyCheckbox_Changed"/>
                            <TextBlock Grid.Row="10"
                                       Grid.Column="1"
                                       Text="New GraphMailer version available (requires the update check on the Monitoring page; one email per new version)"
                                       Style="{StaticResource BodyText}"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Periodic report card -->
            <Border Style="{StaticResource Card}"
                    Margin="0,16,0,0">
                <StackPanel>
                    <Border Style="{StaticResource CardHeader}">
                        <StackPanel>
                            <TextBlock Text="Periodic Reports"
                                       Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="Send an HTML operations report (health checks, statistics, mail queue status and recent failures) to the admin recipients above on a weekly or monthly schedule. Uses the sender address from Notification Settings."
                                       Style="{StaticResource HintText}"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <StackPanel Margin="16,12,16,16">

                        <!-- Enable toggle (always active) -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Enable periodic reports"
                                       Style="{StaticResource LabelText}"
                                       VerticalAlignment="Center"/>
                            <CheckBox  Grid.Column="2"
                                       x:Name="ReportEnabled"
                                       Style="{StaticResource ToggleSwitch}"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Checked="ReportEnabled_Changed"
                                       Unchecked="ReportEnabled_Changed"/>
                        </Grid>

                        <!-- Schedule fields (greyed + disabled when not enabled) -->
                        <Grid x:Name="ReportFields">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Frequency"
                                       Style="{StaticResource LabelText}"
                                       VerticalAlignment="Center"/>
                            <ComboBox  Grid.Row="0" Grid.Column="2"
                                       x:Name="ReportFrequencyBox"
                                       Width="160" HorizontalAlignment="Left"
                                       SelectionChanged="ReportFrequency_Changed">
                                <ComboBoxItem Content="Weekly"/>
                                <ComboBoxItem Content="Monthly"/>
                            </ComboBox>

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       x:Name="ReportDayOfWeekLabel"
                                       Text="Day of week"
                                       Style="{StaticResource LabelText}"
                                       VerticalAlignment="Center"/>
                            <ComboBox  Grid.Row="2" Grid.Column="2"
                                       x:Name="ReportDayOfWeekBox"
                                       Width="160" HorizontalAlignment="Left"
                                       SelectionChanged="AnyCombo_Changed">
                                <ComboBoxItem Content="Sunday"/>
                                <ComboBoxItem Content="Monday"/>
                                <ComboBoxItem Content="Tuesday"/>
                                <ComboBoxItem Content="Wednesday"/>
                                <ComboBoxItem Content="Thursday"/>
                                <ComboBoxItem Content="Friday"/>
                                <ComboBoxItem Content="Saturday"/>
                            </ComboBox>

                            <TextBlock Grid.Row="4" Grid.Column="0"
                                       x:Name="ReportDayOfMonthLabel"
                                       Text="Day of month"
                                       Style="{StaticResource LabelText}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox x:Name="ReportDayOfMonthBox" Width="64"
                                         h:NumericField.Min="1" h:NumericField.Max="28"
                                         ToolTip="Day of the month to send on (1–28, so it exists in every month)."
                                         TextChanged="AnyField_Changed"/>
                                <TextBlock Text="(1–28)" Style="{StaticResource HintText}"
                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>

                            <TextBlock Grid.Row="6" Grid.Column="0"
                                       Text="Time of day"
                                       Style="{StaticResource LabelText}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="6" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox x:Name="ReportHourBox" Width="48" MaxLength="2"
                                         h:NumericField.Min="0" h:NumericField.Max="23"
                                         ToolTip="Hour (0–23)" TextChanged="AnyField_Changed"/>
                                <TextBlock Text=":" FontSize="16" Margin="6,0,6,0" VerticalAlignment="Center"/>
                                <TextBox x:Name="ReportMinuteBox" Width="48" MaxLength="2"
                                         h:NumericField.Min="0" h:NumericField.Max="59"
                                         ToolTip="Minute (0–59)" TextChanged="AnyField_Changed"/>
                                <TextBlock Text="(24-hour, HH:mm — service local time)" Style="{StaticResource HintText}"
                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
