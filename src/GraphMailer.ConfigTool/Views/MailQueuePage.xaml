<UserControl x:Class="GraphMailer.ConfigTool.Views.MailQueuePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:GraphMailer.ConfigTool.Helpers"
             Background="{StaticResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24,20,24,24">

            <!-- Retry & polling card -->
            <Border Style="{StaticResource Card}"
                    Margin="0,0,0,16">
                <StackPanel>
                    <Border Style="{StaticResource CardHeader}">
                        <TextBlock Text="Retry &amp; Polling"
                                   Style="{StaticResource SectionHeader}"/>
                    </Border>
                    <Grid Margin="16,12,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 0: polling · transient retries · transient interval -->
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="Polling interval (seconds)"
                                       Style="{StaticResource LabelText}"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="PollingInterval"
                                     Text="5"
                                     h:NumericField.Min="1"
                                     h:NumericField.Max="1440"
                                     ToolTip="How often the queue directory is scanned for new messages (seconds).&#x0a;Lower = faster pickup, higher = less CPU load.&#x0a;Range: 1 s – 1440 s (24 h)."
                                     TextChanged="AnyField_Changed"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="Transient retries (count)"
                                       Style="{StaticResource LabelText}"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="TransientCount"
                                     Text="6"
                                     h:NumericField.Min="0"
                                     h:NumericField.Max="20"
                                     ToolTip="Number of fast initial retries for transient failures, before switching to the steady interval.&#x0a;Exchange default: 6. Range: 0 – 20."
                                     TextChanged="AnyField_Changed"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="4">
                            <TextBlock Text="Transient interval (seconds)"
                                       Style="{StaticResource LabelText}"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="TransientInterval"
                                     Text="300"
                                     h:NumericField.Min="10"
                                     h:NumericField.Max="3600"
                                     ToolTip="Wait between the fast transient retries (seconds).&#x0a;Exchange default: 300 s (5 min). Range: 10 s – 3600 s."
                                     TextChanged="AnyField_Changed"/>
                        </StackPanel>

                        <!-- Row 2: steady interval · message expiration -->
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="Steady interval (seconds)"
                                       Style="{StaticResource LabelText}"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="SteadyInterval"
                                     Text="900"
                                     h:NumericField.Min="30"
                                     h:NumericField.Max="86400"
                                     ToolTip="Retry interval after the transient phase (seconds).&#x0a;Exchange default: 900 s (15 min); RFC 5321 suggests ≥ 30 min. Range: 30 s – 86400 s."
                                     TextChanged="AnyField_Changed"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="Message expiration (hours)"
                                       Style="{StaticResource LabelText}"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="ExpirationHours"
                                     Text="24"
                                     h:NumericField.Min="0"
                                     h:NumericField.Max="240"
                                     ToolTip="How long a message is retried before it is given up (NDR + moved to failed), measured from receipt.&#x0a;Exchange Online ≈ 24 h; RFC 5321 suggests 4–5 days. 0 = fail on first error. Range: 0 – 240 h."
                                     TextChanged="AnyField_Changed"/>
                        </StackPanel>

                        <!-- Derived retry schedule (read-only, recomputed live) -->
                        <Border Grid.Row="4"
                                Grid.ColumnSpan="5"
                                Background="#F6F8FA"
                                BorderBrush="#D0D7DE"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="Calculated retry schedule"
                                           Style="{StaticResource LabelText}"/>
                                <TextBlock x:Name="RetryScheduleText"
                                           Style="{StaticResource HintText}"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,0"
                                           ToolTip="Derived live from the retry settings above. This is exactly the schedule the service applies (transient retries, then the steady interval, until expiration)."/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Mail directories card -->
            <Border Style="{StaticResource Card}"
                    Margin="0,0,0,16">
                <StackPanel>
                    <Border Style="{StaticResource CardHeader}">
                        <TextBlock Text="Mail Directories"
                                   Style="{StaticResource SectionHeader}"/>
                    </Border>
                    <StackPanel Margin="16,12,16,16">

                        <!-- Mail base directory (configurable) -->
                        <TextBlock Text="Mail base directory"
                                   Style="{StaticResource LabelText}"
                                   Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <TextBox x:Name="QueueDir"
                                         IsReadOnly="True"
                                         ToolTip="Parent folder for all mail sub-directories (queue/, sent/, failed/).&#x0a;Leave empty to use the default: %ProgramData%\GraphMailer\mail&#x0a;Use the Browse button to select a custom path."
                                         TextChanged="QueueDir_Changed"/>
                                <TextBlock Text="{Binding Tag, ElementName=QueueDir}"
                                           Margin="7,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Opacity="0.55"
                                           FontSize="12"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=QueueDir}"
                                                             Value="">
                                                    <Setter Property="Visibility"
                                                            Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Button Grid.Column="1"
                                    Content="…"
                                    Style="{StaticResource SmallButton}"
                                    Width="32"
                                    Height="26"
                                    Padding="4,2"
                                    Margin="4,0,0,0"
                                    ToolTip="Browse for a folder"
                                    Click="BrowseQueueDir_Click"/>
                            <Button Grid.Column="2"
                                    Content="✕"
                                    Style="{StaticResource SmallDangerButton}"
                                    Width="26"
                                    Height="26"
                                    Padding="4,2"
                                    Margin="4,0,0,0"
                                    ToolTip="Reset to default path"
                                    Click="ClearQueueDir_Click"/>
                        </Grid>

                        <!-- Queue directory (derived) -->
                        <TextBlock Text="Queue directory"
                                   Style="{StaticResource LabelText}"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="QueueSubDir"
                                 IsReadOnly="True"
                                 IsEnabled="False"
                                 Margin="0,0,0,10"
                                 ToolTip="Derived from Mail base directory. Incoming messages are stored here until delivered."/>

                        <!-- Sent directory (derived) -->
                        <TextBlock Text="Sent directory"
                                   Style="{StaticResource LabelText}"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="SentDir"
                                 IsReadOnly="True"
                                 IsEnabled="False"
                                 Margin="0,0,0,10"
                                 ToolTip="Derived from Mail base directory. Successfully delivered messages are archived here (when archiving is enabled)."/>

                        <!-- Failed directory (derived) -->
                        <TextBlock Text="Failed directory"
                                   Style="{StaticResource LabelText}"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="FailedDir"
                                 IsReadOnly="True"
                                 IsEnabled="False"
                                 ToolTip="Derived from Mail base directory. Messages that exhausted all retry attempts are moved here for manual inspection."/>

                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Archiving card -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <Border Style="{StaticResource CardHeader}">
                        <TextBlock Text="Archiving &amp; Cleanup"
                                   Style="{StaticResource SectionHeader}"/>
                    </Border>
                    <StackPanel Margin="16,12,16,16">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <CheckBox x:Name="ArchivingEnabled"
                                      Style="{StaticResource ToggleSwitch}"
                                      Checked="AnyCheckbox_Changed"
                                      Unchecked="AnyCheckbox_Changed"/>
                            <TextBlock Text="Enable archiving of sent mail"
                                       Margin="10,0,0,0"
                                       Style="{StaticResource BodyText}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Both retention rows share one fixed label column so the
                             fields sit at the card's left edge and the hints align. -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Retention (days)"
                                           Style="{StaticResource LabelText}"
                                           Margin="0,0,0,4"/>
                                <TextBox x:Name="RetentionDays"
                                         Text="30"
                                         Width="100"
                                         HorizontalAlignment="Left"
                                         h:NumericField.Min="1"
                                         h:NumericField.Max="9125"
                                         ToolTip="How long successfully sent emails are kept in the archive folder before the hourly cleanup deletes them.&#x0a;Range: 1 day – 9125 days (25 years)."
                                         TextChanged="AnyField_Changed"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Margin="16,22,0,0"
                                       Text="Archived mails older than the retention period are deleted by the hourly cleanup job."
                                       Style="{StaticResource HintText}"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Failed-mail retention (days)"
                                           Style="{StaticResource LabelText}"
                                           Margin="0,0,0,4"/>
                                <TextBox x:Name="FailedRetentionDays"
                                         Text="60"
                                         Width="100"
                                         HorizontalAlignment="Left"
                                         h:NumericField.Min="0"
                                         h:NumericField.Max="9125"
                                         ToolTip="How long permanently failed emails are kept in the failed folder before the hourly cleanup deletes them.&#x0a;0 keeps them forever; range up to 9125 days (25 years)."
                                         TextChanged="AnyField_Changed"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Margin="16,22,0,0"
                                       Text="Permanently failed mails are kept for diagnosis, then deleted by the hourly cleanup. 0 = keep forever."
                                       Style="{StaticResource HintText}"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
