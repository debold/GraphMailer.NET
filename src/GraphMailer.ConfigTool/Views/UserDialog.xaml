<Window x:Class="GraphMailer.ConfigTool.Views.UserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User"
        Width="400"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Icon="/Assets/graphmailer.ico"
        Loaded="Window_Loaded"
        Background="{StaticResource BackgroundBrush}">
    <StackPanel Margin="24">

        <!-- Enabled -->
        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,14">
            <CheckBox x:Name="EnabledBox"
                      Style="{StaticResource ToggleSwitch}"
                      VerticalAlignment="Center"/>
            <TextBlock VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       Foreground="{StaticResource TextBrush}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text"
                                Value="Disabled"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=EnabledBox}"
                                         Value="True">
                                <Setter Property="Text"
                                        Value="Enabled"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <!-- Username -->
        <TextBlock Text="Username"
                   Style="{StaticResource LabelText}"
                   Margin="0,0,0,4"/>
        <TextBox x:Name="UsernameBox"
                 TextChanged="Validate"/>

        <!-- Password with inline eye toggle -->
        <TextBlock Text="Password"
                   Style="{StaticResource LabelText}"
                   Margin="0,10,0,4"/>

        <!-- Capture toggle -->
        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,8">
            <CheckBox x:Name="CaptureBox"
                      Style="{StaticResource ToggleSwitch}"
                      VerticalAlignment="Center"
                      Checked="Capture_Changed"
                      Unchecked="Capture_Changed"/>
            <TextBlock Text="Capture password on next SMTP login"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       Foreground="{StaticResource TextBrush}"/>
        </StackPanel>
        <TextBlock Text="The service will accept any password on the first login and store it encrypted. No password entry needed."
                   x:Name="CaptureHint"
                   Style="{StaticResource HintText}"
                   Visibility="Collapsed"
                   TextWrapping="Wrap"
                   Margin="0,0,0,6"/>

        <!-- Password fields (hidden when capture active) -->
        <StackPanel x:Name="PasswordPanel">
            <Grid>
                <PasswordBox x:Name="PasswordBox"
                             Padding="6,4,30,4"
                             PasswordChanged="PasswordBox_Changed"/>
                <TextBox x:Name="PasswordReveal"
                         Padding="6,4,30,4"
                         Visibility="Collapsed"
                         TextChanged="PasswordReveal_Changed"/>
                <Button x:Name="RevealButton"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Width="26"
                        Margin="0,0,3,0"
                        Content="&#x1F441;"
                        FontSize="13"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Focusable="False"
                        ToolTip="Show / hide password"
                        Click="Reveal_Click"/>
            </Grid>

            <!-- Confirm Password -->
            <TextBlock Text="Confirm Password"
                       Style="{StaticResource LabelText}"
                       Margin="0,10,0,4"/>
            <Grid>
                <PasswordBox x:Name="ConfirmBox"
                             Padding="6,4,30,4"
                             PasswordChanged="PasswordBox_Changed"/>
                <TextBox x:Name="ConfirmReveal"
                         Padding="6,4,30,4"
                         Visibility="Collapsed"
                         TextChanged="PasswordReveal_Changed"/>
            </Grid>
        </StackPanel>

        <!-- Display Name -->
        <TextBlock Text="Display Name"
                   Style="{StaticResource LabelText}"
                   Margin="0,10,0,4"/>
        <TextBox x:Name="DisplayNameBox"
                 TextChanged="Validate"/>

        <!-- From Restrictions -->
        <TextBlock Text="Allowed MAIL FROM (optional)"
                   Style="{StaticResource LabelText}"
                   Margin="0,10,0,4"/>
        <TextBox x:Name="FromRestrictionsBox"
                 TextChanged="Validate"
                 ToolTip="Comma-separated list of addresses or @domain patterns this user is allowed to send from.&#x0a;Leave empty to allow any MAIL FROM address.&#x0a;Examples: user@corp.com, @corp.com"/>
        <TextBlock Text="Leave empty to allow any sender address. Separate multiple entries with commas."
                   Style="{StaticResource HintText}"
                   Margin="0,3,0,0"
                   TextWrapping="Wrap"/>

        <!-- Inline error -->
        <TextBlock x:Name="ErrorText"
                   Foreground="{StaticResource DangerBrush}"
                   FontSize="12"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Click="Cancel_Click"/>
            <Button x:Name="OkButton"
                    Content="OK"
                    Style="{StaticResource PrimaryButton}"
                    IsDefault="True"
                    IsEnabled="False"
                    Click="Ok_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
