<UserControl x:Class="GraphMailer.ConfigTool.Views.MessagesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <!-- One card holding toolbar, list and details — the details panel is part of the
         same surface as the list (same layout as the Metrics page's Activity tab). -->
    <!-- Bottom padding = the card's corner radius: the grid paints an opaque background
         and would otherwise cover the rounded bottom corners (the header solves the same
         problem with its own CornerRadius, which a DataGrid cannot carry). -->
    <Border Margin="24,20,24,24"
            Padding="0,0,0,8"
            Style="{StaticResource Card}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"
                               MinHeight="120"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Toolbar ─────────────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Style="{StaticResource CardHeader}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Folder"
                                   Style="{StaticResource LabelText}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <ComboBox x:Name="FolderSelect"
                                  Width="140"
                                  SelectionChanged="Folder_Changed"/>
                    </StackPanel>

                    <!-- No refresh button: the page reloads itself every 5 seconds while it is
                         visible, and there is no way to pause that. No details toggle either —
                         selecting a row opens the panel, its ✕ closes it again. -->
                    <TextBlock x:Name="CountText"
                               Grid.Column="2"
                               Style="{StaticResource HintText}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ── Message grid ─────────────────────────────────────────────── -->
                <DataGrid x:Name="MessagesGrid"
                          Grid.Row="1"
                          Margin="0"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          AutoGenerateColumns="False"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          SelectionChanged="MessagesGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Received"
                                            Binding="{Binding ReceivedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                            Width="140"/>
                        <!-- Only meaningful in the "All" folder, toggled from code-behind.
                             Coloured pill, same treatment as the level column on the Logs page. -->
                        <DataGridTemplateColumn x:Name="StatusColumn"
                                                Header="Status"
                                                Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3"
                                            Padding="6,1"
                                            Background="{Binding StatusBg}"
                                            HorizontalAlignment="Left"
                                            Margin="2,1">
                                        <TextBlock Text="{Binding StatusLabel}"
                                                   Foreground="{Binding StatusFg}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="From"
                                            Binding="{Binding From}"
                                            Width="200"/>
                        <DataGridTextColumn Header="To"
                                            Binding="{Binding To}"
                                            Width="200"/>
                        <DataGridTextColumn Header="Subject"
                                            Binding="{Binding Subject}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Attempts"
                                            Binding="{Binding Attempts}"
                                            Width="75"/>
                    </DataGrid.Columns>
                </DataGrid>

            <!-- ── Details panel ──────────────────────────────────────────────── -->
            <Border x:Name="MessageDetails"
                    Grid.Row="2"
                    Visibility="Collapsed"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- The subject has its own row below, so the header stays a plain title -->
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Details"
                               Style="{StaticResource SectionHeader}"
                               VerticalAlignment="Center"
                               Margin="16,10,0,0"/>

                    <!-- Closes the panel by dropping the grid selection -->
                    <Button x:Name="MessageDetailsClose"
                            Grid.Row="0"
                            Grid.Column="1"
                            VerticalAlignment="Top"
                            Width="22"
                            Height="22"
                            Margin="0,8,10,0"
                            Padding="0"
                            Content="&#x2715;"
                            FontSize="10"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Focusable="False"
                            ToolTip="Close details"
                            Click="MessageDetailsClose_Click"/>

                    <!-- Label/value raster with fixed label columns and fixed row heights,
                         identical to the Activity tab on the Metrics page. -->
                    <Grid Grid.Row="1"
                          Grid.Column="0"
                          Grid.ColumnSpan="2"
                          Margin="16,8,16,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="96"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="96"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="22"/>
                            <RowDefinition Height="22"/>
                            <RowDefinition Height="22"/>
                            <RowDefinition Height="22"/>
                            <RowDefinition Height="22"/>
                            <RowDefinition Height="22"/>
                            <RowDefinition Height="22"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.Resources>
                            <Style x:Key="DetailLabel"
                                   TargetType="TextBlock"
                                   BasedOn="{StaticResource LabelText}">
                                <Setter Property="Margin"
                                        Value="0,0,10,0"/>
                                <Setter Property="VerticalAlignment"
                                        Value="Center"/>
                            </Style>
                            <Style x:Key="DetailValue"
                                   TargetType="TextBlock">
                                <Setter Property="Margin"
                                        Value="0,0,24,0"/>
                                <Setter Property="FontSize"
                                        Value="12.5"/>
                                <Setter Property="VerticalAlignment"
                                        Value="Center"/>
                                <Setter Property="TextTrimming"
                                        Value="CharacterEllipsis"/>
                            </Style>
                            <!-- Shared by the values worth pasting elsewhere -->
                            <ContextMenu x:Key="CopyMenu">
                                <MenuItem Header="Copy"
                                          Click="DetailCopy_Click"/>
                            </ContextMenu>
                        </Grid.Resources>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Subject"
                                   Style="{StaticResource DetailLabel}"/>
                        <TextBlock x:Name="DetailSubjectValue"
                                   Grid.Row="0"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="3"
                                   Style="{StaticResource DetailValue}"
                                   FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Text="Received"
                                   Style="{StaticResource DetailLabel}"/>
                        <TextBlock x:Name="DetailReceived"
                                   Grid.Row="1"
                                   Grid.Column="1"
                                   Style="{StaticResource DetailValue}"/>
                        <TextBlock Grid.Row="1"
                                   Grid.Column="2"
                                   Text="Status"
                                   Style="{StaticResource DetailLabel}"/>
                        <TextBlock x:Name="DetailStatus"
                                   Grid.Row="1"
                                   Grid.Column="3"
                                   Style="{StaticResource DetailValue}"/>

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Text="From"
                                   Style="{StaticResource DetailLabel}"/>
                        <TextBlock x:Name="DetailFrom"
                                   Grid.Row="2"
                                   Grid.Column="1"
                                   Style="{StaticResource DetailValue}"/>
                        <TextBlock Grid.Row="2"
                                   Grid.Column="2"
                                   Text="To"
                                   Style="{StaticResource DetailLabel}"/>
                        <TextBlock x:Name="DetailTo"
                                   Grid.Row="2"
                                   Grid.Column="3"
                                   Style="{StaticResource DetailValue}"/>

                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Text="Sent"
                                   Style="{StaticResource DetailLabel}"/>
                        <TextBlock x:Name="DetailSent"
                                   Grid.Row="3"
                                   Grid.Column="1"
                                   Style="{StaticResource DetailValue}"/>
                        <TextBlock Grid.Row="3"
                                   Grid.Column="2"
                                   Text="Client IP"
                                   Style="{StaticResource DetailLabel}"/>
                        <TextBlock x:Name="DetailClientIp"
                                   Grid.Row="3"
                                   Grid.Column="3"
                                   Style="{StaticResource DetailValue}"/>

                        <TextBlock Grid.Row="4"
                                   Grid.Column="0"
                                   Text="Attempts"
                                   Style="{StaticResource DetailLabel}"/>
                        <TextBlock x:Name="DetailAttempts"
                                   Grid.Row="4"
                                   Grid.Column="1"
                                   Style="{StaticResource DetailValue}"/>
                        <TextBlock Grid.Row="4"
                                   Grid.Column="2"
                                   Text="Last attempt"
                                   Style="{StaticResource DetailLabel}"/>
                        <TextBlock x:Name="DetailLastAttempt"
                                   Grid.Row="4"
                                   Grid.Column="3"
                                   Style="{StaticResource DetailValue}"/>

                        <TextBlock Grid.Row="5"
                                   Grid.Column="0"
                                   Text="Next retry"
                                   Style="{StaticResource DetailLabel}"/>
                        <TextBlock x:Name="DetailNextRetry"
                                   Grid.Row="5"
                                   Grid.Column="1"
                                   Style="{StaticResource DetailValue}"/>
                        <TextBlock Grid.Row="5"
                                   Grid.Column="2"
                                   Text="Message-ID"
                                   Style="{StaticResource DetailLabel}"/>
                        <TextBlock x:Name="DetailMessageId"
                                   Grid.Row="5"
                                   Grid.Column="3"
                                   Style="{StaticResource DetailValue}"
                                   ContextMenu="{StaticResource CopyMenu}"
                                   ToolTip="Right-click to copy"/>

                        <TextBlock Grid.Row="6"
                                   Grid.Column="0"
                                   Text="Queue ID"
                                   Style="{StaticResource DetailLabel}"/>
                        <TextBlock x:Name="DetailQueueId"
                                   Grid.Row="6"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="3"
                                   Style="{StaticResource DetailValue}"
                                   ContextMenu="{StaticResource CopyMenu}"
                                   ToolTip="Right-click to copy"/>

                        <!-- Last row grows with the text, so its label sits at the top -->
                        <TextBlock Grid.Row="7"
                                   Grid.Column="0"
                                   Text="Last error"
                                   Style="{StaticResource DetailLabel}"
                                   VerticalAlignment="Top"
                                   Margin="0,4,10,0"/>
                        <TextBlock x:Name="DetailLastError"
                                   Grid.Row="7"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="3"
                                   Style="{StaticResource DetailValue}"
                                   VerticalAlignment="Top"
                                   Margin="0,3,24,0"
                                   TextTrimming="None"
                                   TextWrapping="Wrap"
                                   ContextMenu="{StaticResource CopyMenu}"
                                   ToolTip="Right-click to copy"/>
                    </Grid>
                </Grid>
            </Border>

            <TextBlock x:Name="EmptyHint"
                       Grid.Row="3"
                       Style="{StaticResource HintText}"
                       TextWrapping="Wrap"
                       Margin="16,8,16,4"
                       Visibility="Collapsed"/>
        </Grid>
    </Border>
</UserControl>
