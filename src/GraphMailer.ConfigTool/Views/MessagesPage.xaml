<UserControl x:Class="GraphMailer.ConfigTool.Views.MessagesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="24,20,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"
                    MinHeight="120"/>
            <RowDefinition x:Name="SplitterRow"
                    Height="0"/>
            <RowDefinition x:Name="DetailsRow"
                    Height="0"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Style="{StaticResource Card}"
                Padding="12,10"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Folder"
                               Style="{StaticResource LabelText}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <ComboBox x:Name="FolderSelect"
                              Width="140"
                              SelectionChanged="Folder_Changed"/>
                    <Button x:Name="BtnToggleDetails"
                            Content="▼ Details"
                            Style="{StaticResource SecondaryButton}"
                            Padding="8,2"
                            FontSize="11"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Click="BtnToggleDetails_Click"/>
                </StackPanel>

                <TextBlock x:Name="CountText"
                           Grid.Column="2"
                           Style="{StaticResource HintText}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="4"
                        Content="&#x21BB; Refresh"
                        Style="{StaticResource SecondaryButton}"
                        Padding="10,4"
                        Click="Refresh_Click"/>
            </Grid>
        </Border>

        <!-- ── Message grid ─────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Style="{StaticResource Card}"
                Padding="0">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Bottom"
                           x:Name="EmptyHint"
                           Style="{StaticResource HintText}"
                           TextWrapping="Wrap"
                           Margin="16,8,16,12"
                           Visibility="Collapsed"/>

                <DataGrid x:Name="MessagesGrid"
                          Margin="0"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          AutoGenerateColumns="False"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          SelectionChanged="MessagesGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Received"
                                            Binding="{Binding ReceivedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                            Width="140"/>
                        <DataGridTextColumn Header="From"
                                            Binding="{Binding From}"
                                            Width="200"/>
                        <DataGridTextColumn Header="To"
                                            Binding="{Binding To}"
                                            Width="200"/>
                        <DataGridTextColumn Header="Subject"
                                            Binding="{Binding Subject}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Attempts"
                                            Binding="{Binding Attempts}"
                                            Width="75"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- ── Splitter ───────────────────────────────────────────────────── -->
        <GridSplitter Grid.Row="2"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="{StaticResource BorderBrush}"
                      Margin="0,1"/>

        <!-- ── Details panel ──────────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Style="{StaticResource Card}"
                Padding="0"
                Margin="0,4,0,0">
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="12,7">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Details"
                                   Style="{StaticResource SectionHeader}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="DetailSubject"
                                   Visibility="Collapsed"
                                   Style="{StaticResource LabelText}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
                <TextBox x:Name="DetailText"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         FontFamily="Consolas"
                         FontSize="12"
                         Padding="12,8"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Text="Select a message to see details."/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
