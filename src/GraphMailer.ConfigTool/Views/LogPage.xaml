<UserControl x:Class="GraphMailer.ConfigTool.Views.LogPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="24,20,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"
                    MinHeight="120"/>
            <RowDefinition x:Name="SplitterRow"
                    Height="0"/>
            <RowDefinition x:Name="DetailsRow"
                    Height="0"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Style="{StaticResource Card}"
                Padding="12,10"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Level filter -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Level"
                               Style="{StaticResource LabelText}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <ComboBox x:Name="LevelFilter"
                              Width="110"
                              SelectedIndex="0"
                              ToolTip="Shows entries of the selected level and above&#x0a;(e.g. Debug+ includes Information, Warning, Error and Fatal)."
                              SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="Debug+"/>
                        <ComboBoxItem Content="Information+"/>
                        <ComboBoxItem Content="Warning+"/>
                        <ComboBoxItem Content="Error+"/>
                        <ComboBoxItem Content="Fatal"/>
                    </ComboBox>
                </StackPanel>

                <!-- Component filter -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Component"
                               Style="{StaticResource LabelText}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <ComboBox x:Name="ComponentFilter"
                              Width="160"
                              SelectedIndex="0"
                              SelectionChanged="Filter_Changed"/>
                </StackPanel>

                <!-- Text search -->
                <Grid Grid.Column="4">
                    <TextBox x:Name="SearchBox"
                             VerticalAlignment="Center"
                             TextChanged="Filter_Changed"/>
                    <TextBlock Text="Search…"
                               Foreground="#FF888888"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility"
                                        Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}"
                                                 Value="">
                                        <Setter Property="Visibility"
                                                Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Auto-refresh toggle (live tail) -->
                <StackPanel Grid.Column="6"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            ToolTip="Reload the log every 5 seconds and jump to the newest entry.&#x0a;Disable to freeze the view while reading or searching — the Refresh button still works.">
                    <CheckBox x:Name="AutoScrollCheck"
                              IsChecked="True"
                              VerticalAlignment="Center"
                              Margin="0,0,6,0"
                              Checked="AutoScroll_Changed"
                              Unchecked="AutoScroll_Changed"/>
                    <TextBlock Text="Auto-refresh"
                               Style="{StaticResource LabelText}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Refresh now -->
                <Button Grid.Column="8"
                        Content="⟳ Refresh"
                        Style="{StaticResource SecondaryButton}"
                        Padding="10,4"
                        Click="BtnRefresh_Click"/>
            </Grid>
        </Border>

        <!-- ── Log grid ──────────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Style="{StaticResource Card}"
                Padding="0"
                Margin="0,0,0,0">
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Log Entries"
                                   Style="{StaticResource SectionHeader}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="EntryCountText"
                                   Text=""
                                   Style="{StaticResource LabelText}"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                        <Button x:Name="BtnToggleDetails"
                                Content="▼ Details"
                                Style="{StaticResource SecondaryButton}"
                                Padding="8,2"
                                FontSize="11"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                Click="BtnToggleDetails_Click"/>
                    </StackPanel>
                </Border>

                <DataGrid x:Name="LogGrid"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          AutoGenerateColumns="False"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          FontFamily="Consolas"
                          FontSize="12"
                          SelectionChanged="LogGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time"
                                            Binding="{Binding TimeLocal}"
                                            Width="160"/>
                        <DataGridTemplateColumn Header="Level"
                                                Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3"
                                            Padding="6,1"
                                            Background="{Binding LevelBg}"
                                            HorizontalAlignment="Left"
                                            Margin="2,1">
                                        <TextBlock Text="{Binding LevelShort}"
                                                   Foreground="{Binding LevelFg}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Component"
                                            Binding="{Binding Component}"
                                            Width="160"/>
                        <DataGridTextColumn Header="Message"
                                            Binding="{Binding Message}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- ── Splitter ───────────────────────────────────────────────────── -->
        <GridSplitter Grid.Row="2"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="{StaticResource BorderBrush}"
                      Margin="0,1"/>

        <!-- ── Details panel ──────────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Style="{StaticResource Card}"
                Padding="0"
                Margin="0,4,0,0">
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="12,7">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Details"
                                   Style="{StaticResource SectionHeader}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="DetailLevelBadge"
                                   Visibility="Collapsed"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                FontWeight="SemiBold"
                                   FontFamily="Consolas"/>
                        <TextBlock x:Name="DetailTimestamp"
                                   Visibility="Collapsed"
                                   Style="{StaticResource LabelText}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                        <TextBlock x:Name="DetailComponent"
                                   Visibility="Collapsed"
                                   Style="{StaticResource LabelText}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
                <TextBox x:Name="DetailText"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         FontSize="12"
                         BorderThickness="0"
                         Padding="12,6"
                         VerticalContentAlignment="Top"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         Text="Select a log entry to see details."
                         Foreground="#FF888888">
                    <TextBox.Style>
                        <Style TargetType="TextBox"
                                BasedOn="{StaticResource {x:Type TextBox}}">
                            <Style.Triggers>
                                <Trigger Property="IsReadOnly"
                                        Value="True">
                                    <Setter Property="Background"
                                            Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </DockPanel>
        </Border>

    </Grid>
</UserControl>
