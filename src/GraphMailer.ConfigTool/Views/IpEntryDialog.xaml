<Window x:Class="GraphMailer.ConfigTool.Views.IpEntryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IP Entry"
        Width="420"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Icon="/Assets/graphmailer.ico"
        Loaded="Window_Loaded"
        Background="{StaticResource BackgroundBrush}">
    <StackPanel Margin="24">

        <!-- IP / CIDR -->
        <TextBlock x:Name="DescriptionText"
                   Style="{StaticResource HintText}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>
        <TextBlock Text="IP Address or CIDR Block"
                Style="{StaticResource LabelText}"
                Margin="0,0,0,4"/>
        <TextBox x:Name="EntryBox"
                TextChanged="EntryBox_TextChanged"/>

        <!-- Inline error -->
        <TextBlock x:Name="ErrorText"
                   Foreground="{StaticResource DangerBrush}"
                   FontSize="12"
                Margin="0,6,0,0"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"/>

        <!-- Comment (optional) -->
        <TextBlock Text="Comment (optional)"
                Style="{StaticResource LabelText}"
                Margin="0,12,0,4"/>
        <TextBox x:Name="CommentBox"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,18,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Click="Cancel_Click"/>
            <Button x:Name="OkButton"
                    Content="OK"
                    Style="{StaticResource PrimaryButton}"
                    IsDefault="True"
                    IsEnabled="False"
                    Click="Ok_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
