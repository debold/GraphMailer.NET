<Window x:Class="GraphMailer.ConfigTool.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set Password"
        Width="360"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/graphmailer.ico"
        Background="{StaticResource BackgroundBrush}">
    <StackPanel Margin="24">
        <TextBlock x:Name="UserLabel"
                Text="Password for user"
                Style="{StaticResource LabelText}"
                Margin="0,0,0,6"/>
        <PasswordBox x:Name="PwBox"/>
        <PasswordBox x:Name="PwConfirm"
                Margin="0,8,0,0"/>
        <TextBlock x:Name="ErrText"
                Foreground="{StaticResource DangerBrush}"
                   FontSize="12"
                Margin="0,6,0,0"
                Visibility="Collapsed"/>
        <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,16,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Set Password"
                    Style="{StaticResource PrimaryButton}"
                    Click="Ok_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
