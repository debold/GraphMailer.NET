                                                                                   Style="{StaticResource HintText}"
                                                                                   Margin="16,0,16,12"/>
                                                                </StackPanel>
                                                        </Border>
                                                        <Border Grid.Column="2"
                                                                Style="{StaticResource Card}">
                                                                <StackPanel>
                                                                        <Border Style="{StaticResource CardHeader}">
                                                                                <TextBlock Text="Rejections by Reason"
                                                                                           Style="{StaticResource SectionHeader}"/>
                                                                        </Border>
                                                                        <DataGrid x:Name="RcRejectionsGrid"
                                                                                  MinHeight="80"
                                                                                  MaxHeight="240"
                                                                                  CanUserAddRows="False"
                                                                                  AutoGenerateColumns="False"
                                                                                  IsReadOnly="True">
                                                                                <DataGrid.Columns>
                                                                                        <DataGridTextColumn Header="Reason"
                                                                                                            Binding="{Binding Name}"
                                                                                                            Width="*"/>
