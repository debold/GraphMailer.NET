<UserControl x:Class="GraphMailer.ConfigTool.Views.MetricsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
        <UserControl.Resources>

                <!-- Flat tab strip matching the app's light Fluent look -->
                <Style x:Key="StatsTabItem"
                       TargetType="TabItem">
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                                <Border x:Name="Bd"
                                                        Background="Transparent"
                                                        BorderThickness="0,0,0,2.5"
                                                        BorderBrush="Transparent"
                                                        Padding="16,8,16,9"
                                                        Margin="0,0,2,0">
                                                        <TextBlock x:Name="Txt"
                                                                   Text="{TemplateBinding Header}"
                                                                   FontSize="13.5"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected"
                                                                 Value="True">
                                                                <Setter TargetName="Bd"
                                                                        Property="BorderBrush"
                                                                        Value="{StaticResource AccentBrush}"/>
                                                                <Setter TargetName="Txt"
                                                                        Property="Foreground"
                                                                        Value="{StaticResource AccentBrush}"/>
                                                                <Setter TargetName="Txt"
                                                                        Property="FontWeight"
                                                                        Value="SemiBold"/>
                                                        </Trigger>
                                                        <MultiTrigger>
                                                                <MultiTrigger.Conditions>
                                                                        <Condition Property="IsMouseOver"
                                                                                   Value="True"/>
                                                                        <Condition Property="IsSelected"
                                                                                   Value="False"/>
                                                                </MultiTrigger.Conditions>
                                                                <Setter TargetName="Txt"
                                                                        Property="Foreground"
                                                                        Value="{StaticResource TextBrush}"/>
                                                        </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <!-- KPI card building blocks -->
                <Style x:Key="KpiValue"
                       TargetType="TextBlock">
                        <Setter Property="FontSize"
                                Value="25"/>
                        <Setter Property="FontWeight"
                                Value="SemiBold"/>
                        <Setter Property="Margin"
                                Value="0,5,0,0"/>
                        <Setter Property="Foreground"
                                Value="{StaticResource TextBrush}"/>
                </Style>
                <Style x:Key="KpiSub"
                       TargetType="TextBlock">
                        <Setter Property="FontSize"
                                Value="11.5"/>
                        <Setter Property="Foreground"
                                Value="{StaticResource TextSecondaryBrush}"/>
                        <Setter Property="Margin"
                                Value="0,3,0,0"/>
                        <Setter Property="TextTrimming"
                                Value="CharacterEllipsis"/>
                </Style>

                <!-- Horizontal proportional bar row (distributions, funnels) -->
                <DataTemplate x:Key="HBarTemplate">
                        <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Name}"
                                           FontSize="12.5"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <Grid Grid.Column="1"
                                      Height="14"
                                      VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="{Binding FillStar}"/>
                                                <ColumnDefinition Width="{Binding RestStar}"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.ColumnSpan="2"
                                                Background="#F0F0F0"
                                                CornerRadius="3"/>
                                        <Border Grid.Column="0"
                                                Background="{Binding Fill}"
                                                CornerRadius="3"
                                                MinWidth="2"/>
                                </Grid>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding CountText}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"/>
                        </Grid>
                </DataTemplate>

        </UserControl.Resources>

        <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header: global time range + refresh -->
                <Grid Grid.Row="0"
                      Margin="24,16,24,0">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                                <TextBlock Text="Time range:"
                                           Style="{StaticResource LabelText}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <Button x:Name="Range24h"
                                        Content="24h"
                                        Style="{StaticResource SmallButton}"
                                        Margin="0,0,4,0"
                                        Tag="1"
                                        Click="Range_Click"/>
                                <Button x:Name="Range7d"
                                        Content="7d"
                                        Style="{StaticResource SmallPrimaryButton}"
                                        Margin="0,0,4,0"
                                        Tag="7"
                                        Click="Range_Click"/>
                                <Button x:Name="Range30d"
                                        Content="30d"
                                        Style="{StaticResource SmallButton}"
                                        Margin="0,0,4,0"
                                        Tag="30"
                                        Click="Range_Click"/>
                                <!-- No refresh button: the page reloads itself every 5 seconds while
                                     it is visible, and there is no way to pause that. -->
                                <Button x:Name="Range90d"
                                        Content="90d"
                                        Style="{StaticResource SmallButton}"
                                        Tag="90"
                                        Click="Range_Click"/>
                        </StackPanel>
                </Grid>

                <TabControl Grid.Row="1"
                            x:Name="StatsTabs"
                            Margin="24,8,24,20"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0">

                        <!-- ══════════ OVERVIEW ══════════ -->
                        <TabItem Header="Overview"
                                 Style="{StaticResource StatsTabItem}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel Margin="0,14,0,4">
                                                <Grid Margin="0,0,0,14">
                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0"
                                                                Style="{StaticResource Card}"
                                                                Padding="16,13">
                                                                <StackPanel>
                                                                        <TextBlock Text="Received"
                                                                                   Style="{StaticResource LabelText}"/>
                                                                        <TextBlock x:Name="OvReceived"
                                                                                   Text="—"
                                                                                   Style="{StaticResource KpiValue}"/>
                                                                        <TextBlock Text="mails accepted"
                                                                                   Style="{StaticResource KpiSub}"/>
                                                                </StackPanel>
                                                        </Border>
                                                        <Border Grid.Column="2"
                                                                Style="{StaticResource Card}"
                                                                Padding="16,13">
                                                                <StackPanel>
                                                                        <TextBlock Text="Delivered"
                                                                                   Style="{StaticResource LabelText}"/>
                                                                        <TextBlock x:Name="OvDelivered"
                                                                                   Text="—"
                                                                                   Style="{StaticResource KpiValue}"
                                                                                   Foreground="{StaticResource AccentBrush}"/>
                                                                        <TextBlock Text="via Graph API"
                                                                                   Style="{StaticResource KpiSub}"/>
                                                                </StackPanel>
                                                        </Border>
                                                        <Border Grid.Column="4"
                                                                Style="{StaticResource Card}"
                                                                Padding="16,13">
                                                                <StackPanel>
                                                                        <TextBlock Text="Failed"
                                                                                   Style="{StaticResource LabelText}"/>
                                                                        <TextBlock x:Name="OvFailed"
                                                                                   Text="—"
                                                                                   Style="{StaticResource KpiValue}"
                                                                                   Foreground="{StaticResource DangerBrush}"/>
                                                                        <TextBlock x:Name="OvFailedSub"
                                                                                   Text="permanently failed"
                                                                                   Style="{StaticResource KpiSub}"/>
                                                                </StackPanel>
                                                        </Border>
                                                        <Border Grid.Column="6"
                                                                Style="{StaticResource Card}"
                                                                Padding="16,13">
                                                                <StackPanel>
                                                                        <TextBlock Text="Success Rate"
                                                                                   Style="{StaticResource LabelText}"/>
                                                                        <TextBlock x:Name="OvSuccessRate"
                                                                                   Text="—"
                                                                                   Style="{StaticResource KpiValue}"
                                                                                   Foreground="{StaticResource OkBrush}"/>
                                                                        <TextBlock Text="delivered / (delivered + failed)"
                                                                                   Style="{StaticResource KpiSub}"/>
                                                                </StackPanel>
                                                        </Border>
                                                </Grid>

                                                <Border Style="{StaticResource Card}"
                                                        Margin="0,0,0,14">
                                                        <StackPanel>
                                                                <Border Style="{StaticResource CardHeader}">
                                                                        <TextBlock Text="Mail Flow per Day"
                                                                                   Style="{StaticResource SectionHeader}"/>
                                                                </Border>
                                                                <Canvas x:Name="DailyCanvas"
                                                                        Height="180"
                                                                        Margin="12,10,12,2"
                                                                        ClipToBounds="True"
                                                                        SizeChanged="DailyCanvas_SizeChanged"/>
                                                                <StackPanel Orientation="Horizontal"
                                                                            Margin="16,2,16,10">
                                                                        <Border Width="10"
                                                                                Height="10"
                                                                                CornerRadius="2"
                                                                                Background="{StaticResource AccentBrush}"
                                                                                VerticalAlignment="Center"/>
                                                                        <TextBlock Text="Delivered"
                                                                                   Style="{StaticResource KpiSub}"
                                                                                   Margin="5,0,14,0"/>
                                                                        <Border Width="10"
                                                                                Height="10"
                                                                                CornerRadius="2"
                                                                                Background="{StaticResource DangerBrush}"
                                                                                VerticalAlignment="Center"/>
                                                                        <TextBlock Text="Failed"
                                                                                   Style="{StaticResource KpiSub}"
                                                                                   Margin="5,0,0,0"/>
                                                                </StackPanel>
                                                        </StackPanel>
                                                </Border>

                                                <Grid Margin="0,0,0,14">
                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0"
                                                                Style="{StaticResource Card}"
                                                                Padding="16,13">
                                                                <StackPanel>
                                                                        <TextBlock Text="Volume"
                                                                                   Style="{StaticResource LabelText}"/>
                                                                        <TextBlock x:Name="OvVolume"
                                                                                   Text="—"
                                                                                   Style="{StaticResource KpiValue}"
                                                                                   FontSize="21"/>
                                                                        <TextBlock x:Name="OvVolumeSub"
                                                                                   Text="Ø per mail"
                                                                                   Style="{StaticResource KpiSub}"/>
                                                                </StackPanel>
                                                        </Border>
                                                        <Border Grid.Column="2"
                                                                Style="{StaticResource Card}"
                                                                Padding="16,13">
                                                                <StackPanel>
                                                                        <TextBlock Text="Avg. Delivery"
                                                                                   Style="{StaticResource LabelText}"/>
                                                                        <TextBlock x:Name="OvAvgDelivery"
                                                                                   Text="—"
                                                                                   Style="{StaticResource KpiValue}"
                                                                                   FontSize="21"/>
                                                                        <TextBlock x:Name="OvAvgDeliverySub"
                                                                                   Text="max —"
                                                                                   Style="{StaticResource KpiSub}"/>
                                                                </StackPanel>
                                                        </Border>
                                                        <Border Grid.Column="4"
                                                                Style="{StaticResource Card}"
                                                                Padding="16,13">
                                                                <StackPanel>
                                                                        <TextBlock Text="Unique Senders"
                                                                                   Style="{StaticResource LabelText}"/>
                                                                        <TextBlock x:Name="OvSenders"
                                                                                   Text="—"
                                                                                   Style="{StaticResource KpiValue}"
                                                                                   FontSize="21"/>
                                                                        <TextBlock x:Name="OvSendersSub"
                                                                                   Text=""
                                                                                   Style="{StaticResource KpiSub}"/>
                                                                </StackPanel>
                                                        </Border>
                                                        <Border Grid.Column="6"
                                                                Style="{StaticResource Card}"
                                                                Padding="16,13">
                                                                <StackPanel>
                                                                        <TextBlock Text="Queued Now"
                                                                                   Style="{StaticResource LabelText}"/>
                                                                        <TextBlock x:Name="OvQueuedNow"
                                                                                   Text="—"
                                                                                   Style="{StaticResource KpiValue}"
                                                                                   FontSize="21"/>
                                                                        <TextBlock Text="waiting for delivery"
                                                                                   Style="{StaticResource KpiSub}"/>
                                                                </StackPanel>
                                                        </Border>
                                                </Grid>

                                        </StackPanel>
                                </ScrollViewer>
                        </TabItem>

                        <!-- ══════════ ACTIVITY ══════════ -->
                        <!-- Own tab rather than the tail of Overview: the grid fills the height,
                             so the details panel is always visible without scrolling. -->
                        <TabItem Header="Activity"
                                 Style="{StaticResource StatsTabItem}">
                                <!-- Bottom padding = the card's corner radius: the grid paints an opaque
                                     background and would otherwise cover the rounded bottom corners
                                     (the header solves this with its own CornerRadius, which a
                                     DataGrid cannot carry). -->
                                <Border Style="{StaticResource Card}"
                                        Margin="0,14,0,4"
                                        Padding="0,0,0,8">
                                        <Grid>
                                                <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Border Grid.Row="0"
                                                        Style="{StaticResource CardHeader}">
                                                        <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0"
                                                                           Text="Recent Activity"
                                                                           Style="{StaticResource SectionHeader}"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock x:Name="ActivityCountText"
                                                                           Grid.Column="1"
                                                                           Style="{StaticResource HintText}"
                                                                           Margin="0,0,10,0"
                                                                           VerticalAlignment="Center"/>
                                                                <!-- Live search over the loaded rows (same pattern as the log viewer) -->
                                                                <Grid Grid.Column="2"
                                                                      Width="220">
                                                                        <TextBox x:Name="ActivitySearchBox"
                                                                                 VerticalAlignment="Center"
                                                                                 Padding="6,4,26,4"
                                                                                 ToolTip="Filters the events below on every field, including the ones shown only in the details panel."
                                                                                 TextChanged="ActivitySearch_Changed"/>
                                                                        <TextBlock Text="Search…"
                                                                                   Foreground="#FF888888"
                                                                                   Margin="6,0,0,0"
                                                                                   VerticalAlignment="Center"
                                                                                   IsHitTestVisible="False">
                                                                                <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                                <Setter Property="Visibility"
                                                                                                        Value="Collapsed"/>
                                                                                                <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding Text, ElementName=ActivitySearchBox}"
                                                                                                                     Value="">
                                                                                                                <Setter Property="Visibility"
                                                                                                                        Value="Visible"/>
                                                                                                        </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                        </Style>
                                                                                </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <!-- Clear button, shown only while the box has content
                                                                             (mirrors the reveal button in the user dialog) -->
                                                                        <Button x:Name="ActivitySearchClear"
                                                                                HorizontalAlignment="Right"
                                                                                VerticalAlignment="Center"
                                                                                Width="22"
                                                                                Margin="0,0,3,0"
                                                                                Padding="0"
                                                                                Content="&#x2715;"
                                                                                FontSize="10"
                                                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                                                Background="Transparent"
                                                                                BorderThickness="0"
                                                                                Cursor="Hand"
                                                                                Focusable="False"
                                                                                ToolTip="Clear search"
                                                                                Click="ActivitySearchClear_Click">
                                                                                <Button.Style>
                                                                                        <!-- No BasedOn: the app has no implicit Button style,
                                                                                             only keyed ones (same as the reveal button) -->
                                                                                        <Style TargetType="Button">
                                                                                                <Setter Property="Visibility"
                                                                                                        Value="Visible"/>
                                                                                                <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding Text, ElementName=ActivitySearchBox}"
                                                                                                                     Value="">
                                                                                                                <Setter Property="Visibility"
                                                                                                                        Value="Collapsed"/>
                                                                                                        </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                        </Style>
                                                                                </Button.Style>
                                                                        </Button>
                                                                </Grid>
                                                        </Grid>
                                                </Border>

                                                <!-- Few columns, the flexible one last (same layout as the Logs grid):
                                                     a star column between pixel columns is re-measured to "whatever is
                                                     left" on every layout pass, which undoes any width the user drags.
                                                     Everything else moved into the details panel. -->
                                                <DataGrid x:Name="ActivityGrid"
                                                          Grid.Row="1"
                                                          Margin="0"
                                                          MinHeight="120"
                                                          CanUserAddRows="False"
                                                          CanUserDeleteRows="False"
                                                          AutoGenerateColumns="False"
                                                          SelectionMode="Single"
                                                          IsReadOnly="True"
                                                          SelectionChanged="ActivityGrid_SelectionChanged">
                                                        <DataGrid.Columns>
                                                                <DataGridTextColumn Header="Timestamp"
                                                                                    Binding="{Binding Timestamp}"
                                                                                    Width="150"/>
                                                                <DataGridTextColumn Header="Event"
                                                                                    Binding="{Binding Event}"
                                                                                    Width="75"/>
                                                                <DataGridTextColumn Header="From"
                                                                                    Binding="{Binding From}"
                                                                                    Width="200"/>
                                                                <DataGridTextColumn Header="To"
                                                                                    Binding="{Binding To}"
                                                                                    Width="200"/>
                                                                <DataGridTextColumn Header="Subject"
                                                                                    Binding="{Binding Subject}"
                                                                                    Width="*"/>
                                                        </DataGrid.Columns>
                                                </DataGrid>

                                                <!-- Details of the selected event. Fixed label columns and fixed row
                                                     heights keep every label/value pair on the same grid, whatever the
                                                     text is — a taller glyph must not shift its row. -->
                                                <Border x:Name="ActivityDetails"
                                                        Grid.Row="2"
                                                        Visibility="Collapsed"
                                                        BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="0,1,0,0"
                                                        Padding="16,12,16,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <!-- Closes the panel by dropping the grid selection -->
                                                        <Button x:Name="ActivityDetailsClose"
                                                                Grid.Column="1"
                                                                VerticalAlignment="Top"
                                                                Width="22"
                                                                Height="22"
                                                                Padding="0"
                                                                Content="&#x2715;"
                                                                FontSize="10"
                                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                                Background="Transparent"
                                                                BorderThickness="0"
                                                                Cursor="Hand"
                                                                Focusable="False"
                                                                ToolTip="Close details"
                                                                Click="ActivityDetailsClose_Click"/>
                                                        <Grid Grid.Column="0">
                                                                <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="96"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="96"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                        <RowDefinition Height="22"/>
                                                                        <RowDefinition Height="22"/>
                                                                        <RowDefinition Height="22"/>
                                                                        <RowDefinition Height="22"/>
                                                                        <RowDefinition Height="22"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <Grid.Resources>
                                                                        <Style x:Key="DetailLabel"
                                                                               TargetType="TextBlock"
                                                                               BasedOn="{StaticResource LabelText}">
                                                                                <Setter Property="Margin"
                                                                                        Value="0,0,10,0"/>
                                                                                <Setter Property="VerticalAlignment"
                                                                                        Value="Center"/>
                                                                        </Style>
                                                                        <Style x:Key="DetailValue"
                                                                               TargetType="TextBlock">
                                                                                <Setter Property="Margin"
                                                                                        Value="0,0,24,0"/>
                                                                                <Setter Property="FontSize"
                                                                                        Value="12.5"/>
                                                                                <Setter Property="VerticalAlignment"
                                                                                        Value="Center"/>
                                                                                <Setter Property="TextTrimming"
                                                                                        Value="CharacterEllipsis"/>
                                                                        </Style>
                                                                </Grid.Resources>

                                                                <TextBlock Grid.Row="0"
                                                                           Grid.Column="0"
                                                                           Text="Subject"
                                                                           Style="{StaticResource DetailLabel}"/>
                                                                <TextBlock x:Name="DetailSubject"
                                                                           Grid.Row="0"
                                                                           Grid.Column="1"
                                                                           Grid.ColumnSpan="3"
                                                                           Style="{StaticResource DetailValue}"
                                                                           FontWeight="SemiBold"/>

                                                                <TextBlock Grid.Row="1"
                                                                           Grid.Column="0"
                                                                           Text="From"
                                                                           Style="{StaticResource DetailLabel}"/>
                                                                <TextBlock x:Name="DetailFrom"
                                                                           Grid.Row="1"
                                                                           Grid.Column="1"
                                                                           Style="{StaticResource DetailValue}"/>
                                                                <TextBlock Grid.Row="1"
                                                                           Grid.Column="2"
                                                                           Text="To"
                                                                           Style="{StaticResource DetailLabel}"/>
                                                                <TextBlock x:Name="DetailTo"
                                                                           Grid.Row="1"
                                                                           Grid.Column="3"
                                                                           Style="{StaticResource DetailValue}"/>

                                                                <TextBlock Grid.Row="2"
                                                                           Grid.Column="0"
                                                                           Text="Size"
                                                                           Style="{StaticResource DetailLabel}"/>
                                                                <TextBlock x:Name="DetailSize"
                                                                           Grid.Row="2"
                                                                           Grid.Column="1"
                                                                           Style="{StaticResource DetailValue}"/>
                                                                <TextBlock Grid.Row="2"
                                                                           Grid.Column="2"
                                                                           Text="Attachments"
                                                                           Style="{StaticResource DetailLabel}"/>
                                                                <TextBlock x:Name="DetailAttachments"
                                                                           Grid.Row="2"
                                                                           Grid.Column="3"
                                                                           Style="{StaticResource DetailValue}"/>

                                                                <TextBlock Grid.Row="3"
                                                                           Grid.Column="0"
                                                                           Text="Listener"
                                                                           Style="{StaticResource DetailLabel}"/>
                                                                <TextBlock x:Name="DetailListener"
                                                                           Grid.Row="3"
                                                                           Grid.Column="1"
                                                                           Style="{StaticResource DetailValue}"/>
                                                                <TextBlock Grid.Row="3"
                                                                           Grid.Column="2"
                                                                           Text="TLS"
                                                                           Style="{StaticResource DetailLabel}"/>
                                                                <TextBlock x:Name="DetailTls"
                                                                           Grid.Row="3"
                                                                           Grid.Column="3"
                                                                           Style="{StaticResource DetailValue}"/>

                                                                <TextBlock Grid.Row="4"
                                                                           Grid.Column="0"
                                                                           Text="Auth"
                                                                           Style="{StaticResource DetailLabel}"/>
                                                                <TextBlock x:Name="DetailAuth"
                                                                           Grid.Row="4"
                                                                           Grid.Column="1"
                                                                           Style="{StaticResource DetailValue}"/>
                                                                <TextBlock Grid.Row="4"
                                                                           Grid.Column="2"
                                                                           Text="Duration"
                                                                           Style="{StaticResource DetailLabel}"/>
                                                                <TextBlock x:Name="DetailDuration"
                                                                           Grid.Row="4"
                                                                           Grid.Column="3"
                                                                           Style="{StaticResource DetailValue}"/>

                                                                <!-- Last row grows with the text, so its label sits at the top -->
                                                                <TextBlock x:Name="DetailDetailLabel"
                                                                           Grid.Row="5"
                                                                           Grid.Column="0"
                                                                           Text="Message ID"
                                                                           Style="{StaticResource DetailLabel}"
                                                                           VerticalAlignment="Top"
                                                                           Margin="0,4,10,0"/>
                                                                <!-- A TextBlock, not a read-only TextBox: a TextBox indents its text by
                                                                     its content host's gutter and greys it out via the IsReadOnly
                                                                     trigger, so the row would not line up with the values above.
                                                                     Copying is offered through the context menu instead. -->
                                                                <TextBlock x:Name="DetailDetail"
                                                                           Grid.Row="5"
                                                                           Grid.Column="1"
                                                                           Grid.ColumnSpan="3"
                                                                           Style="{StaticResource DetailValue}"
                                                                           VerticalAlignment="Top"
                                                                           Margin="0,3,24,0"
                                                                           TextTrimming="None"
                                                                           TextWrapping="Wrap"
                                                                           ToolTip="Right-click to copy">
                                                                        <TextBlock.ContextMenu>
                                                                                <ContextMenu>
                                                                                        <MenuItem Header="Copy"
                                                                                                  Click="DetailDetail_Copy"/>
                                                                                </ContextMenu>
                                                                        </TextBlock.ContextMenu>
                                                                </TextBlock>
                                                        </Grid>
                                                    </Grid>
                                                </Border>

                                                <TextBlock x:Name="NoDataText"
                                                           Grid.Row="3"
                                                           Text="No metrics data available. The service must have processed at least one message."
                                                           Style="{StaticResource HintText}"
                                                           Margin="16,10,16,4"/>
                                        </Grid>
                                </Border>
                        </TabItem>

                        <!-- ══════════ RECEPTION ══════════ -->
                        <TabItem Header="Reception"
                                 Style="{StaticResource StatsTabItem}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel Margin="0,14,0,4">
                                                <Grid Margin="0,0,0,14">
                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0"
