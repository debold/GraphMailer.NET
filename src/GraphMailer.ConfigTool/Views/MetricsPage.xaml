                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0"
                                                                Style="{StaticResource Card}"
                                                                Padding="16,13">
                                                                <StackPanel>
                                                                        <TextBlock Text="Memory (latest)"
                                                                                   Style="{StaticResource LabelText}"/>
                                                                        <TextBlock x:Name="PerfMemory"
                                                                                   Text="—"
                                                                                   Style="{StaticResource KpiValue}"
                                                                                   FontSize="21"
                                                                                   Foreground="{StaticResource AccentBrush}"/>
                                                                        <TextBlock x:Name="PerfMemorySub"
                                                                                   Text=""
                                                                                   Style="{StaticResource KpiSub}"/>
                                                                </StackPanel>
                                                        </Border>
                                                        <Border Grid.Column="2"
                                                                Style="{StaticResource Card}"
                                                                Padding="16,13">
                                                                <StackPanel>
                                                                        <TextBlock Text="CPU (latest)"
                                                                                   Style="{StaticResource LabelText}"/>
                                                                        <TextBlock x:Name="PerfCpu"
                                                                                   Text="—"
                                                                                   Style="{StaticResource KpiValue}"
                                                                                   FontSize="21"/>
                                                                        <TextBlock x:Name="PerfCpuSub"
                                                                                   Text=""
                                                                                   Style="{StaticResource KpiSub}"/>
                                                                </StackPanel>
                                                        </Border>
                                                        <Border Grid.Column="4"
                                                                Style="{StaticResource Card}"
                                                                Padding="16,13">
                                                                <StackPanel>
                                                                        <TextBlock Text="Disk Free (latest)"
                                                                                   Style="{StaticResource LabelText}"/>
                                                                        <TextBlock x:Name="PerfDisk"
                                                                                   Text="—"
                                                                                   Style="{StaticResource KpiValue}"
                                                                                   FontSize="21"
                                                                                   Foreground="{StaticResource OkBrush}"/>
                                                                        <TextBlock Text=""
                                                                                   Style="{StaticResource KpiSub}"/>
                                                                </StackPanel>
                                                        </Border>
                                                        <Border Grid.Column="6"
                                                                Style="{StaticResource Card}"
                                                                Padding="16,13">
                                                                <StackPanel>
                                                                        <TextBlock Text="metrics.db"
                                                                                   Style="{StaticResource LabelText}"/>
                                                                        <TextBlock x:Name="SrvDbSize"
                                                                                   Text="—"
                                                                                   Style="{StaticResource KpiValue}"
                                                                                   FontSize="21"/>
                                                                        <TextBlock x:Name="SrvDbSizeSub"
                                                                                   Text=""
                                                                                   Style="{StaticResource KpiSub}"/>
                                                                </StackPanel>
                                                        </Border>
                                                </Grid>

                                                <Border Style="{StaticResource Card}">
                                                        <StackPanel>
                                                                <Border Style="{StaticResource CardHeader}">
                                                                        <TextBlock Text="Performance"
                                                                                   Style="{StaticResource SectionHeader}"/>
                                                                </Border>
                                                                <Grid Margin="12,8,12,4">
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="12"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="12"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <StackPanel Grid.Column="0">
                                                                                <TextBlock Text="Memory (MB)"
                                                                                           Style="{StaticResource LabelText}"
                                                                                           Margin="0,0,0,4"/>
                                                                                <Canvas x:Name="MemoryCanvas"
                                                                                        Height="100"
                                                                                        HorizontalAlignment="Stretch"
                                                                                        ClipToBounds="True"
                                                                                        SizeChanged="PerfCanvas_SizeChanged"/>
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Column="2">
                                                                                <TextBlock Text="CPU (%)"
                                                                                           Style="{StaticResource LabelText}"
                                                                                           Margin="0,0,0,4"/>
                                                                                <Canvas x:Name="CpuCanvas"
                                                                                        Height="100"
                                                                                        HorizontalAlignment="Stretch"
                                                                                        ClipToBounds="True"
                                                                                        SizeChanged="PerfCanvas_SizeChanged"/>
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Column="4">
                                                                                <TextBlock Text="Disk Free (%)"
                                                                                           Style="{StaticResource LabelText}"
                                                                                           Margin="0,0,0,4"/>
