<UserControl x:Class="GraphMailer.ConfigTool.Views.IpFilteringPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:GraphMailer.ConfigTool.Helpers"
             Background="{StaticResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24,20,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Whitelist card -->
            <Border Grid.Column="0"
                    Grid.Row="0"
                    Style="{StaticResource Card}">
                <StackPanel>
                    <Border Style="{StaticResource CardHeader}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="IP Whitelist"
                                       Style="{StaticResource SectionHeader}"/>
                            <Button Grid.Column="1"
                                    Content="+ Add"
                                    Style="{StaticResource SmallPrimaryButton}"
                                    Click="AddWhitelist_Click"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="When the whitelist is not empty, only listed IPs/CIDRs may send mail — all others are rejected at MAIL FROM."
                               Style="{StaticResource HintText}"
                               Margin="16,10,16,0"/>
                    <DataGrid x:Name="WhitelistGrid"
                              Margin="0,4,0,0"
                              MinHeight="60"
                              MaxHeight="240"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="IP / CIDR"
                                                Binding="{Binding Entry}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Comment"
                                                Binding="{Binding Comment}"
                                                Width="140"/>
                            <DataGridTemplateColumn Header=""
                                                    Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center">
                                            <Button Content="✎"
                                                    Style="{StaticResource SmallButton}"
                                                    Padding="6,2"
                                                    Height="22"
                                                    Margin="0,0,4,0"
                                                    Click="EditWhitelist_Click"/>
                                            <Button Content="✕"
                                                    Style="{StaticResource SmallDangerButton}"
                                                    Padding="6,2"
                                                    Height="22"
                                                    Click="RemoveWhitelist_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Blacklist card -->
            <Border Grid.Column="2"
                    Grid.Row="0"
                    Style="{StaticResource Card}">
                <StackPanel>
                    <Border Style="{StaticResource CardHeader}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="IP Blacklist"
                                       Style="{StaticResource SectionHeader}"/>
                            <Button Grid.Column="1"
                                    Content="+ Add"
                                    Style="{StaticResource SmallPrimaryButton}"
                                    Click="AddBlacklist_Click"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="Blacklisted IPs/CIDRs are rejected at MAIL FROM."
                               Style="{StaticResource HintText}"
                               Margin="16,10,16,0"/>
                    <DataGrid x:Name="BlacklistGrid"
                              Margin="0,4,0,0"
                              MinHeight="60"
                              MaxHeight="240"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="IP / CIDR"
                                                Binding="{Binding Entry}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Comment"
                                                Binding="{Binding Comment}"
                                                Width="140"/>
                            <DataGridTemplateColumn Header=""
                                                    Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center">
                                            <Button Content="✎"
                                                    Style="{StaticResource SmallButton}"
                                                    Padding="6,2"
                                                    Height="22"
                                                    Margin="0,0,4,0"
                                                    Click="EditBlacklist_Click"/>
                                            <Button Content="✕"
                                                    Style="{StaticResource SmallDangerButton}"
                                                    Padding="6,2"
                                                    Height="22"
                                                    Click="RemoveBlacklist_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Auto-blocking settings -->
            <Border Grid.Column="0"
                    Grid.Row="2"
                    Grid.ColumnSpan="3"
                    Style="{StaticResource Card}">
                <StackPanel>
                    <Border Style="{StaticResource CardHeader}">
                        <TextBlock Text="Automatic IP Blocking"
                                   Style="{StaticResource SectionHeader}"/>
                    </Border>
                    <Grid Margin="16,12,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Max failures"
                                       Style="{StaticResource LabelText}"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="MaxFailures"
                                     Text="10"
                                     Width="80"
                                     h:NumericField.Min="1"
                                    h:NumericField.Max="100"
                                     ToolTip="Number of failed authentication or filter-rejection events from a single IP within the time window before it is blocked automatically.&#x0a;Range: 1 – 100."
                                     TextChanged="AnyField_Changed"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Within (minutes)"
                                       Style="{StaticResource LabelText}"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="WindowMinutes"
                                     Text="10"
                                     Width="80"
                                     h:NumericField.Min="1"
                                    h:NumericField.Max="1440"
                                     ToolTip="Sliding time window in which failures are counted. The counter resets when the window expires without reaching the threshold.&#x0a;Range: 1 – 1440 min (24 h)."
                                     TextChanged="AnyField_Changed"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Block duration (minutes)"
                                       Style="{StaticResource LabelText}"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="BlockMinutes"
                                     Text="10"
                                     Width="100"
                                     h:NumericField.Min="1"
                                    h:NumericField.Max="1440"
                                     ToolTip="How long the IP remains blocked after the threshold is exceeded. All connections from that IP are rejected until the block expires.&#x0a;Range: 1 – 1440 min (24 h)."
                                     TextChanged="AnyField_Changed"/>
                        </StackPanel>
                        <TextBlock Grid.Column="5"
                                   Margin="16,18,0,0"
                                   Text="Block an IP after N failures within the window. Default: 10 / 10 min → 10 min block."
                                   Style="{StaticResource HintText}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Currently blocked IPs (runtime data) -->
            <Border Grid.Column="0"
                    Grid.Row="4"
                    Grid.ColumnSpan="3"
                    Style="{StaticResource Card}">
                <StackPanel>
                    <Border Style="{StaticResource CardHeader}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Currently Blocked IPs"
                                       Style="{StaticResource SectionHeader}"/>
                            <Button Grid.Column="1"
                                    Content="↺ Refresh"
                                    Style="{StaticResource SmallButton}"
                                    Click="RefreshBlocked_Click"/>
                        </Grid>
                    </Border>
                    <DataGrid x:Name="BlockedGrid"
                              Margin="0"
                              MinHeight="60"
                              MaxHeight="240"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="IP Address"
                                                Binding="{Binding IpAddress}"
                                                Width="160"/>
                            <DataGridTextColumn Header="Failures"
                                                Binding="{Binding Failures}"
                                                Width="80"/>
                            <DataGridTextColumn Header="Blocked At"
                                                Binding="{Binding BlockedAt}"
                                                Width="160"/>
                            <DataGridTextColumn Header="Unblocks At"
                                                Binding="{Binding UnblocksAt}"
                                                Width="160"/>
                            <DataGridTemplateColumn Header=""
                                                    Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Unblock"
                                                Style="{StaticResource SmallButton}"
                                                Click="Unblock_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock x:Name="NoBlockedText"
                               Text="No IPs are currently blocked."
                               Style="{StaticResource HintText}"
                               Margin="16,10,16,12"
                               Visibility="Visible"/>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>
