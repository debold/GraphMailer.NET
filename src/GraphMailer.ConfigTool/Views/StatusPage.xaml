<UserControl x:Class="GraphMailer.ConfigTool.Views.StatusPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24,20,24,24">

            <!-- Config-secret decryption warning (shown when a secret cannot be decrypted) -->
            <Border x:Name="SecretsBanner"
                    Visibility="Collapsed"
                    Background="#FFFDE7E9"
                    BorderBrush="#FFC42B1C"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,10"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="SecretsBannerText"
                               Grid.Column="0"
                               Foreground="#FFC42B1C"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="&#x2715;"
                               Foreground="#FFC42B1C"
                               FontSize="14"
                               Margin="12,0,2,0"
                               VerticalAlignment="Top"
                               Cursor="Hand"
                               ToolTip="Dismiss"
                               MouseLeftButtonUp="SecretsBannerDismiss_Click"/>
                </Grid>
            </Border>

            <!-- KPI cards row -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Delivered Today -->
                <Border Grid.Column="0"
                        Style="{StaticResource Card}"
                        Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="Delivered Today"
                                   Style="{StaticResource LabelText}"/>
                        <TextBlock x:Name="KpiDelivered"
                                   Text="—"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource OkBrush}"
                                   Margin="0,6,0,2"/>
                        <TextBlock x:Name="KpiDeliveredSub"
                                   Text="loading…"
                                   Style="{StaticResource HintText}"/>
                    </StackPanel>
                </Border>

                <!-- Queued -->
                <Border Grid.Column="2"
                        Style="{StaticResource Card}"
                        Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="Queued"
                                   Style="{StaticResource LabelText}"/>
                        <TextBlock x:Name="KpiQueued"
                                   Text="—"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"
                                   Margin="0,6,0,2"/>
                        <TextBlock x:Name="KpiQueuedSub"
                                   Text="loading…"
                                   Style="{StaticResource HintText}"/>
                    </StackPanel>
                </Border>

                <!-- Failed -->
                <Border Grid.Column="4"
                        Style="{StaticResource Card}"
                        Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="Failed Today"
                                   Style="{StaticResource LabelText}"/>
                        <TextBlock x:Name="KpiFailed"
                                   Text="—"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DangerBrush}"
                                   Margin="0,6,0,2"/>
                        <TextBlock x:Name="KpiFailedSub"
                                   Text="loading…"
                                   Style="{StaticResource HintText}"/>
                    </StackPanel>
                </Border>

                <!-- Uptime -->
                <Border Grid.Column="6"
                        Style="{StaticResource Card}"
                        Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="Uptime"
                                   Style="{StaticResource LabelText}"/>
                        <TextBlock x:Name="KpiUptime"
                                   Text="—"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,6,0,2"/>
                        <TextBlock x:Name="KpiUptimeSub"
                                   Text="loading…"
                                   Style="{StaticResource HintText}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Service Control card -->
            <Border Style="{StaticResource Card}"
                    Margin="0,0,0,20">
                <StackPanel>
                    <Border Style="{StaticResource CardHeader}">
                        <TextBlock Text="Service Control"
                                   Style="{StaticResource SectionHeader}"/>
                    </Border>
                    <Grid Margin="16,14,16,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <!-- Status badge -->
                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Status:"
                                       Style="{StaticResource LabelText}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <Border x:Name="SvcStatusBadge"
                                    CornerRadius="10"
                                    Padding="10,3"
                                    Background="#FFF0F0F0"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="SvcStatusText"
                                           Text="Unknown"
                                           FontSize="12"
                                           Foreground="#FF616161"/>
                            </Border>
                        </StackPanel>
                        <!-- Action buttons -->
                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal">
                            <Button x:Name="BtnStart"
                                    Content="Start"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,8,0"
                                    Click="BtnStart_Click"/>
                            <Button x:Name="BtnStop"
                                    Content="Stop"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,8,0"
                                    Click="BtnStop_Click"/>
                            <Button x:Name="BtnRestart"
                                    Content="Restart"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,24,0"
                                    Click="BtnRestart_Click"/>
                            <Button x:Name="BtnInstall"
                                    Content="Install"
                                    Style="{StaticResource SuccessButton}"
                                    Margin="0,0,8,0"
                                    Click="BtnInstall_Click"/>
                            <Button x:Name="BtnUninstall"
                                    Content="Uninstall"
                                    Style="{StaticResource DangerButton}"
                                    Click="BtnUninstall_Click"/>
                        </StackPanel>
                        <!-- Feedback message -->
                        <TextBlock x:Name="SvcFeedback"
                                   Grid.Row="3"
                                   Style="{StaticResource HintText}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"
                                   Visibility="Collapsed"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Software Update card -->
            <Border Style="{StaticResource Card}"
                    Margin="0,0,0,20">
                <StackPanel>
                    <Border Style="{StaticResource CardHeader}">
                        <TextBlock Text="Software Update"
                                   Style="{StaticResource SectionHeader}"/>
                    </Border>
                    <Grid Margin="16,14,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,6">
                                <TextBlock Text="Installed version:"
                                           Style="{StaticResource LabelText}"
                                           Width="120"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="UpdInstalledVersion"
                                           Text="—"
                                           Style="{StaticResource BodyText}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,6">
                                <TextBlock Text="Latest release:"
                                           Style="{StaticResource LabelText}"
                                           Width="120"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="UpdLatestVersion"
                                           Text="—"
                                           Style="{StaticResource BodyText}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                                <Border x:Name="UpdStatusBadge"
                                        CornerRadius="10"
                                        Padding="10,3"
                                        Background="#FFF0F0F0"
                                        Visibility="Collapsed"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="UpdStatusText"
                                               Text=""
                                               FontSize="12"
                                               Foreground="#FF616161"/>
                                </Border>
                                <TextBlock x:Name="UpdReleaseLink"
                                           Visibility="Collapsed"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0">
                                    <Hyperlink Click="UpdReleaseLink_Click">Release notes</Hyperlink>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock x:Name="UpdDetail"
                                       Style="{StaticResource HintText}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Top">
                            <Button x:Name="BtnUpdateCheck"
                                    Content="Check now"
                                    Style="{StaticResource SecondaryButton}"
                                    ToolTip="Asks the running service to query the GitHub releases immediately."
                                    Click="BtnUpdateCheck_Click"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- System Health card -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <Border Style="{StaticResource CardHeader}">
                        <TextBlock Text="System Health"
                                   Style="{StaticResource SectionHeader}"/>
                    </Border>
                    <DataGrid x:Name="HealthGrid"
                              Margin="0"
                              MinHeight="120"
                              SelectionMode="Single"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Component"
                                                Binding="{Binding Component}"
                                                Width="180"/>
                            <DataGridTemplateColumn Header="Status"
                                                    Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10"
                                                Padding="8,2"
                                                Background="{Binding StatusBg}"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="12"
                                                       Foreground="{Binding StatusFg}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Detail"
                                    Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Detail}"
                                                   TextWrapping="Wrap"
                                                   Padding="6,4"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Last Check"
                                                Binding="{Binding LastCheck}"
                                                Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
