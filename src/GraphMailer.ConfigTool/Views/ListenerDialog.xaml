<Window x:Class="GraphMailer.ConfigTool.Views.ListenerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Listener"
        Width="440"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Icon="/Assets/graphmailer.ico"
        Loaded="Window_Loaded"
        Background="{StaticResource BackgroundBrush}">
    <StackPanel Margin="24">

        <!-- Enabled -->
        <StackPanel Orientation="Horizontal"
                Margin="0,0,0,14">
            <CheckBox x:Name="EnabledBox"
                    Style="{StaticResource ToggleSwitch}"
                    VerticalAlignment="Center"/>
            <TextBlock VerticalAlignment="Center"
                    Margin="10,0,0,0"
                    Foreground="{StaticResource TextBrush}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text"
                                Value="Disabled"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=EnabledBox}"
                                    Value="True">
                                <Setter Property="Text"
                                        Value="Enabled"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <!-- Description -->
        <TextBlock Text="Description"
                Style="{StaticResource LabelText}"
                Margin="0,0,0,4"/>
        <TextBox x:Name="DescriptionBox"
                TextChanged="Validate"/>

        <!-- Port -->
        <TextBlock Text="Port"
                Style="{StaticResource LabelText}"
                Margin="0,12,0,4"/>
        <TextBox x:Name="PortBox"
                TextChanged="Validate"
                Width="120"
                HorizontalAlignment="Left"/>

        <!-- Inline error -->
        <TextBlock x:Name="ErrorText"
                   Foreground="{StaticResource DangerBrush}"
                   FontSize="12"
                Margin="0,6,0,0"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"/>

        <!-- TLS Mode -->
        <TextBlock Text="TLS Mode"
                Style="{StaticResource LabelText}"
                Margin="0,12,0,4"/>
        <ComboBox x:Name="TlsModeBox">
            <ComboBoxItem>None</ComboBoxItem>
            <ComboBoxItem>STARTTLS (optional)</ComboBoxItem>
            <ComboBoxItem>STARTTLS (required)</ComboBoxItem>
            <ComboBoxItem>Implicit TLS</ComboBoxItem>
        </ComboBox>

        <!-- Auth -->
        <TextBlock Text="Authentication"
                Style="{StaticResource LabelText}"
                Margin="0,12,0,4"/>
        <ComboBox x:Name="AuthModeBox">
            <ComboBoxItem>None</ComboBoxItem>
            <ComboBoxItem>Optional</ComboBoxItem>
            <ComboBoxItem>Required</ComboBoxItem>
        </ComboBox>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,18,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Click="Cancel_Click"/>
            <Button x:Name="OkButton"
                    Content="OK"
                    Style="{StaticResource PrimaryButton}"
                    IsDefault="True"
                    IsEnabled="False"
                    Click="Ok_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
