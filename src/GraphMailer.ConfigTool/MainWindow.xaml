<Window x:Class="GraphMailer.ConfigTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:GraphMailer.ConfigTool.Views"
        Title="GraphMailer — Configuration Tool"
        Icon="Assets/graphmailer.ico"
        Width="1180"
        Height="860"
        MinWidth="960"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

        <!-- F1 and the toolbar help icon both raise ApplicationCommands.Help,
             which opens the bundled help page for the current screen. -->
        <Window.CommandBindings>
                <CommandBinding Command="Help"
                                Executed="Help_Executed"/>
        </Window.CommandBindings>

        <Grid>
                <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="224"/>
                        <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ════════ SIDEBAR ════════ -->
                <DockPanel Grid.Column="0"
                           Background="{StaticResource NavBgBrush}"
                           LastChildFill="True">

                        <!-- Logo header -->
                        <Border DockPanel.Dock="Top"
                                Padding="16,18,16,16"
                                BorderBrush="#FF333333"
                                BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                        <!-- Badge-less base icon, generated by tools\generate-icons.ps1 -->
                                        <Image Width="32"
                                               Height="32"
                                               Source="Assets/graphmailer-base.png"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <StackPanel Margin="10,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="GraphMailer"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"/>
                                                <TextBlock Text="Configuration Tool"
                                                           FontSize="11"
                                                           Foreground="#FF999999"/>
                                        </StackPanel>
                                </StackPanel>
                        </Border>

                        <!-- Service status bar -->
                        <Border DockPanel.Dock="Bottom"
                                Padding="16,10"
                                BorderBrush="#FF333333"
                                BorderThickness="0,1,0,0">
                                <StackPanel VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                                <Ellipse x:Name="ServiceStatusDot"
                                                         Width="8"
                                                         Height="8"
                                                         Fill="#FF888888"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,8,0"/>
                                                <TextBlock x:Name="ServiceStatusText"
                                                           Text="Checking…"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"
                                                           VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="ServiceSinceText"
                                                   Text="—"
                                                   FontSize="11"
                                                   Foreground="#FF888888"
                                                   Margin="16,0,0,0"/>
                                </StackPanel>
                        </Border>

                        <!-- Nav items -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>

                                        <!-- Overview -->
                                        <TextBlock Text="OVERVIEW"
                                                   Style="{StaticResource LabelText}"
                                                   Foreground="#FF777777"
                                                   Margin="16,14,16,4"/>
                                        <Border x:Name="NavStatus"
                                                Style="{StaticResource NavItem}"
                                                MouseLeftButtonUp="NavStatus_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#x1F4CA;"
                                                                   FontSize="15"
                                                                   Width="20"
                                                                   TextAlignment="Center"
                                                                   Foreground="#FFCCCCCC"/>
                                                        <TextBlock Text="Status"
                                                                   FontSize="13"
                                                                   Foreground="#FFCCCCCC"
                                                                   Margin="10,0,0,0"/>
                                                </StackPanel>
                                        </Border>

                                        <!-- Configuration (editable settings, Save/Discard apply) -->
                                        <Border BorderBrush="#FF333333"
                                                BorderThickness="0,1,0,0"
                                                Margin="0,12,0,0"/>
                                        <TextBlock Text="CONFIGURATION"
                                                   Style="{StaticResource LabelText}"
                                                   Foreground="#FF777777"
                                                   Margin="16,12,16,4"/>
                                        <Border x:Name="NavSmtp"
                                                Style="{StaticResource NavItem}"
                                                MouseLeftButtonUp="NavSmtp_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#x1F4E8;"
                                                                   FontSize="15"
                                                                   Width="20"
                                                                   TextAlignment="Center"
                                                                   Foreground="#FFCCCCCC"/>
                                                        <TextBlock Text="Servers &amp; TLS"
                                                                   FontSize="13"
                                                                   Foreground="#FFCCCCCC"
                                                                   Margin="10,0,0,0"/>
                                                </StackPanel>
                                        </Border>
                                        <Border x:Name="NavAccess"
                                                Style="{StaticResource NavItem}"
                                                MouseLeftButtonUp="NavAccess_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#x1F510;"
                                                                   FontSize="15"
                                                                   Width="20"
                                                                   TextAlignment="Center"
                                                                   Foreground="#FFCCCCCC"/>
                                                        <TextBlock Text="Access Control"
                                                                   FontSize="13"
                                                                   Foreground="#FFCCCCCC"
                                                                   Margin="10,0,0,0"/>
                                                        <TextBlock x:Name="NavAccessBadge"
                                                                   Text="&#x25CF;"
                                                                   Visibility="Collapsed"
                                                                   FontSize="12"
                                                                   Foreground="#FFE81123"
                                                                   VerticalAlignment="Center"
                                                                   Margin="6,0,0,0"
                                                                   ToolTip="A stored secret on this page could not be decrypted."/>
                                                </StackPanel>
                                        </Border>
                                        <Border x:Name="NavIpFiltering"
                                                Style="{StaticResource NavItem}"
                                                MouseLeftButtonUp="NavIpFiltering_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#x1F6E1;"
                                                                   FontSize="15"
                                                                   Width="20"
                                                                   TextAlignment="Center"
                                                                   Foreground="#FFCCCCCC"/>
                                                        <TextBlock Text="IP Filtering"
                                                                   FontSize="13"
                                                                   Foreground="#FFCCCCCC"
                                                                   Margin="10,0,0,0"/>
                                                </StackPanel>
                                        </Border>

                                        <Border x:Name="NavGraphApi"
                                                Style="{StaticResource NavItem}"
                                                MouseLeftButtonUp="NavGraphApi_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#x2601;"
                                                                   FontSize="15"
                                                                   Width="20"
                                                                   TextAlignment="Center"
                                                                   Foreground="#FFCCCCCC"/>
                                                        <TextBlock Text="Graph API"
                                                                   FontSize="13"
                                                                   Foreground="#FFCCCCCC"
                                                                   Margin="10,0,0,0"/>
                                                        <TextBlock x:Name="NavGraphApiBadge"
                                                                   Text="&#x25CF;"
                                                                   Visibility="Collapsed"
                                                                   FontSize="12"
                                                                   Foreground="#FFE81123"
                                                                   VerticalAlignment="Center"
                                                                   Margin="6,0,0,0"
                                                                   ToolTip="A stored secret on this page could not be decrypted."/>
                                                </StackPanel>
                                        </Border>
                                        <Border x:Name="NavQueue"
                                                Style="{StaticResource NavItem}"
                                                MouseLeftButtonUp="NavQueue_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#x1F4E5;"
                                                                   FontSize="15"
                                                                   Width="20"
                                                                   TextAlignment="Center"
                                                                   Foreground="#FFCCCCCC"/>
                                                        <TextBlock Text="Mail Queue"
                                                                   FontSize="13"
                                                                   Foreground="#FFCCCCCC"
                                                                   Margin="10,0,0,0"/>
                                                </StackPanel>
                                        </Border>

                                        <Border x:Name="NavMonitoring"
                                                Style="{StaticResource NavItem}"
                                                MouseLeftButtonUp="NavMonitoring_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#x1F50D;"
                                                                   FontSize="15"
                                                                   Width="20"
                                                                   TextAlignment="Center"
                                                                   Foreground="#FFCCCCCC"/>
                                                        <TextBlock Text="Health Checks"
                                                                   FontSize="13"
                                                                   Foreground="#FFCCCCCC"
                                                                   Margin="10,0,0,0"/>
                                                </StackPanel>
                                        </Border>
                                        <Border x:Name="NavNotifications"
                                                Style="{StaticResource NavItem}"
                                                MouseLeftButtonUp="NavNotifications_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#x1F514;"
                                                                   FontSize="15"
                                                                   Width="20"
                                                                   TextAlignment="Center"
                                                                   Foreground="#FFCCCCCC"/>
                                                        <TextBlock Text="Notifications"
                                                                   FontSize="13"
                                                                   Foreground="#FFCCCCCC"
                                                                   Margin="10,0,0,0"/>
                                                </StackPanel>
                                        </Border>
                                        <Border x:Name="NavBackup"
                                                Style="{StaticResource NavItem}"
                                                MouseLeftButtonUp="NavBackup_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#x1F4BE;"
                                                                   FontSize="15"
                                                                   Width="20"
                                                                   TextAlignment="Center"
                                                                   Foreground="#FFCCCCCC"/>
                                                        <TextBlock Text="Backup &amp; Restore"
                                                                   FontSize="13"
                                                                   Foreground="#FFCCCCCC"
                                                                   Margin="10,0,0,0"/>
                                                </StackPanel>
                                        </Border>
                                        <!-- Monitoring (read-only runtime data: stats, mail folders, logs) -->
                                        <Border BorderBrush="#FF333333"
                                                BorderThickness="0,1,0,0"
                                                Margin="0,12,0,0"/>
                                        <TextBlock Text="MONITORING"
                                                   Style="{StaticResource LabelText}"
                                                   Foreground="#FF777777"
                                                   Margin="16,12,16,4"/>
                                        <Border x:Name="NavMetrics"
                                                Style="{StaticResource NavItem}"
                                                MouseLeftButtonUp="NavMetrics_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#x1F4C8;"
                                                                   FontSize="15"
                                                                   Width="20"
                                                                   TextAlignment="Center"
                                                                   Tag="monitor"
                                                                   Foreground="{StaticResource NavMonitorIconBrush}"/>
                                                        <TextBlock Text="Metrics"
                                                                   FontSize="13"
                                                                   Foreground="#FFCCCCCC"
                                                                   Margin="10,0,0,0"/>
                                                </StackPanel>
                                        </Border>

                                        <Border x:Name="NavMessages"
                                                Style="{StaticResource NavItem}"
                                                MouseLeftButtonUp="NavMessages_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#x2709;"
                                                                   FontSize="15"
                                                                   Width="20"
                                                                   TextAlignment="Center"
                                                                   Tag="monitor"
                                                                   Foreground="{StaticResource NavMonitorIconBrush}"/>
                                                        <TextBlock Text="Messages"
                                                                   FontSize="13"
                                                                   Foreground="#FFCCCCCC"
                                                                   Margin="10,0,0,0"/>
                                                </StackPanel>
                                        </Border>

                                        <Border x:Name="NavLogs"
                                                Style="{StaticResource NavItem}"
                                                MouseLeftButtonUp="NavLogs_Click">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#x1F4CB;"
                                                                   FontSize="15"
                                                                   Width="20"
                                                                   TextAlignment="Center"
                                                                   Tag="monitor"
                                                                   Foreground="{StaticResource NavMonitorIconBrush}"/>
                                                        <TextBlock Text="Logs"
                                                                   FontSize="13"
                                                                   Foreground="#FFCCCCCC"
                                                                   Margin="10,0,0,0"/>
                                                </StackPanel>
                                        </Border>

                                </StackPanel>
                        </ScrollViewer>
                </DockPanel>

                <!-- ════════ MAIN AREA ════════ -->
                <DockPanel Grid.Column="1"
                           LastChildFill="True">

                        <!-- Toolbar -->
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="24,8">
                                <Grid>
                                        <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock x:Name="PageTitleText"
                                                           Style="{StaticResource PageTitle}"
                                                           Text="Status"
                                                           VerticalAlignment="Center"/>
                                                <!-- Unobtrusive, same place on every page: opens the
                                                     help page matching the current screen (also F1).
                                                     Emoji glyph in the nav-bar style (info "i"). -->
                                                <Button x:Name="HelpButton"
                                                        Command="Help"
                                                        Content="&#x2139;&#xFE0F;"
                                                        FontSize="15"
                                                        Width="26"
                                                        Height="26"
                                                        Padding="0"
                                                        Margin="10,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Foreground="{StaticResource TextSecondaryBrush}"
                                                        Cursor="Hand"
                                                        Focusable="False"
                                                        ToolTip="Open the help for this page (F1)"/>
                                        </StackPanel>
                                        <Border x:Name="UnsavedBadge"
                                                Grid.Column="1"
                                                Background="#FFFFF4CE"
                                                BorderBrush="#FFEDBE00"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="10,2"
                                                Margin="0,0,8,0"
                                                Visibility="Collapsed"
                                                VerticalAlignment="Center">
                                                <TextBlock Text="● Unsaved changes"
                                                           FontSize="11"
                                                           Foreground="#FF7A5700"/>
                                        </Border>
                                        <Border x:Name="RestartBadge"
                                                Grid.Column="2"
                                                Background="#FFFFE4CE"
                                                BorderBrush="#FFED7000"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="10,2"
                                                Margin="0,0,8,0"
                                                Visibility="Collapsed"
                                                VerticalAlignment="Center">
                                                <TextBlock Text="⚠ Restart required"
                                                           FontSize="11"
                                                           Foreground="#FF7A3000"/>
                                        </Border>
                                        <Button Grid.Column="3"
                                                Content="Discard"
                                                Margin="0,0,8,0"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="Discard_Click"/>
                                        <Button x:Name="SaveButton"
                                                Grid.Column="4"
                                                Content="💾 Save"
                                                Style="{StaticResource PrimaryButton}"
                                                Click="Save_Click"/>
                                </Grid>
                        </Border>

                        <!-- Page host -->
                        <ContentControl x:Name="PageHost"
                                        Margin="0"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch"/>
                </DockPanel>
        </Grid>
</Window>