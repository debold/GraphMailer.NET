<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brand -->
    <Color x:Key="AccentColor">#FF0078D4</Color>
    <Color x:Key="AccentHoverColor">#FF106EBE</Color>
    <Color x:Key="DangerColor">#FFC42B1C</Color>
    <Color x:Key="WarnColor">#FF9D5D00</Color>
    <Color x:Key="OkColor">#FF0F7B0F</Color>

    <!-- Surfaces -->
    <Color x:Key="BackgroundColor">#FFF3F3F3</Color>
    <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
    <Color x:Key="NavBgColor">#FF1C1C1C</Color>
    <Color x:Key="NavActiveColor">#FF0078D4</Color>
    <Color x:Key="NavHoverColor">#FF2D2D2D</Color>
    <Color x:Key="NavMonitorIconColor">#FF8FCB8F</Color>
    <Color x:Key="BorderColor">#FFE0E0E0</Color>
    <Color x:Key="TextColor">#FF1A1A1A</Color>
    <Color x:Key="TextSecondaryColor">#FF616161</Color>
    <Color x:Key="TextInverseColor">#FFFFFFFF</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AccentBrush"
            Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush"
            Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="DangerBrush"
            Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="WarnBrush"
            Color="{StaticResource WarnColor}"/>
    <SolidColorBrush x:Key="OkBrush"
            Color="{StaticResource OkColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush"
            Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"
            Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="NavBgBrush"
            Color="{StaticResource NavBgColor}"/>
    <SolidColorBrush x:Key="NavActiveBrush"
            Color="{StaticResource NavActiveColor}"/>
    <SolidColorBrush x:Key="NavHoverBrush"
            Color="{StaticResource NavHoverColor}"/>
    <SolidColorBrush x:Key="NavMonitorIconBrush"
            Color="{StaticResource NavMonitorIconColor}"/>
    <SolidColorBrush x:Key="BorderBrush"
            Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="TextBrush"
            Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"
            Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextInverseBrush"
            Color="{StaticResource TextInverseColor}"/>

    <!-- Badge brushes -->
    <SolidColorBrush x:Key="BadgeOkBg"
            Color="#FFDFF6DD"/>
    <SolidColorBrush x:Key="BadgeWarnBg"
            Color="#FFFFF4CE"/>
    <SolidColorBrush x:Key="BadgeErrBg"
            Color="#FFFDE7E9"/>
    <SolidColorBrush x:Key="BadgeInfoBg"
            Color="#FFEAF3FB"/>
    <SolidColorBrush x:Key="BadgePlainBg"
            Color="#FFF0F0F0"/>
    <SolidColorBrush x:Key="CertSelectedBg"
            Color="#FFEAF3FB"/>
    <SolidColorBrush x:Key="CertSelectedBorder"
            Color="#FFBDD9EF"/>

</ResourceDictionary>
