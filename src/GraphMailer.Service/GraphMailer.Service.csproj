<Project Sdk="Microsoft.NET.Sdk.Worker">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>dotnet-GraphMailer.Service-92b035d8-09e5-4c64-a0d1-794e76280571</UserSecretsId>
    <AssemblyName>GraphMailer</AssemblyName>
    <RootNamespace>GraphMailer.Service</RootNamespace>
    <!-- Generated by tools\generate-icons.ps1 (shared base icon + play badge) -->
    <ApplicationIcon>Assets\graphmailer.ico</ApplicationIcon>
    <!-- Required for top-level return value in Program.cs -->
    <Nullable>enable</Nullable>
  </PropertyGroup>


  <ItemGroup>
    <!-- Dev-only settings never belong in a deployment -->
    <Content Update="appsettings.Development.json" CopyToPublishDirectory="Never" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="GraphMailer.Tests.Unit" />
    <InternalsVisibleTo Include="GraphMailer.Tests.Integration" />
    <InternalsVisibleTo Include="GraphMailer.Tests.Live" />
    <InternalsVisibleTo Include="DynamicProxyGenAssembly2" />
    <InternalsVisibleTo Include="GraphMailer.ConfigTool" />
  </ItemGroup>

  <ItemGroup>
    <!-- All versions pinned (no floating "x.*"): floating versions made release
         builds non-reproducible over time and once combined with a stale
         ReadyToRun cache into a release whose DLLs didn't match its deps.json
         (Microsoft.Data.Sqlite 8.0.28 vs 8.0.29 → FileNotFoundException).
         Upgrade deliberately by bumping the version here. -->
    <PackageReference Include="Azure.Identity" Version="1.21.0" />
    <!-- Base SDK only (TelemetryClient + InMemoryChannel) for the opt-in daily
         telemetry heartbeat — no ASP.NET/auto-collection packages. -->
    <PackageReference Include="Microsoft.ApplicationInsights" Version="2.23.0" />
    <PackageReference Include="Microsoft.AspNetCore.DataProtection" Version="10.0.10" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.10" />
    <!-- Security pin: Microsoft.Data.Sqlite pulls a SQLitePCLRaw whose bundled SQLite is
         affected by CVE-2025-6965 (GHSA-2m69-gcr7-jv3q, memory corruption) — 2.1.6 on the
         8.0.x line, still 2.1.11 on 10.0.10, and the advisory covers everything up to and
         including 2.1.11. Fixed in 2.1.12. The net10.0 move did NOT make this pin redundant;
         drop it only once Microsoft.Data.Sqlite itself resolves 2.1.12 or newer. -->
    <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="2.1.12" />
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="10.0.10" />
    <PackageReference Include="Microsoft.Graph" Version="6.2.0" />
    <PackageReference Include="MimeKit" Version="4.17.0" />
    <!-- Explicit Serilog pin: keeps the shared DLL identical to the one the
         ConfigTool references (both publish into the same release folder) -->
    <PackageReference Include="Serilog" Version="4.4.0" />
    <PackageReference Include="Serilog.Extensions.Hosting" Version="10.0.0" />
    <PackageReference Include="Serilog.Settings.Configuration" Version="10.0.1" />
    <PackageReference Include="Serilog.Sinks.Console" Version="6.1.1" />
    <PackageReference Include="Serilog.Sinks.EventLog" Version="4.0.0" />
    <PackageReference Include="Serilog.Sinks.File" Version="7.0.0" />
    <PackageReference Include="SmtpServer" Version="11.1.0" />
    <!-- Server-side PNG rendering of the periodic-report daily-volume chart.
         Embedded as a CID inline image so it renders in Outlook Classic + new Outlook
         (both strip inline SVG). Platform-neutral (no System.Drawing/CA1416 on the
         Service's platform-agnostic net10.0 target). -->
    <PackageReference Include="SkiaSharp" Version="4.150.1" />
    <PackageReference Include="SkiaSharp.NativeAssets.Win32" Version="4.150.1" />
  </ItemGroup>
</Project>
