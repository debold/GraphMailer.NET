<?xml version="1.0" encoding="utf-8"?>
<!--
  GraphMailer bootstrapper (setup.exe).

  Chains the .NET 10 Desktop Runtime (x64) prerequisite, then the GraphMailer MSI.
  The runtime is downloaded on demand (DownloadUrl), so the bundle stays small; it is
  skipped when the shipped runtime version is already present.

  Built by build-installer.ps1, which passes:
    -d ProductVersion=<x.y.z.build>
    -d MsiPath=<GraphMailer-*.msi>
    -d DotNetVersion=<10.0.x>           (exact shipped runtime version)
    -d DotNetRuntimeExe=<local windowsdesktop-runtime-*.exe>  (for payload hashing)
    -d DotNetRuntimeUrl=<immutable download URL matching the exe>

  Silent install / uninstall:
    GraphMailerSetup-<ver>.exe /quiet /norestart
    GraphMailerSetup-<ver>.exe /uninstall /quiet /norestart
    (also /passive for a progress-only UI)
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:netfx="http://wixtoolset.org/schemas/v4/wxs/netfx"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Bundle Name="GraphMailer"
          Version="$(var.ProductVersion)"
          Manufacturer="marc.debold"
          UpgradeCode="7F3E601B-AD4C-4F8B-9E30-2C5D6B7F8091"
          IconSourceFile="$(var.IconFile)">

    <BootstrapperApplication>
      <!-- LaunchTarget renders a "Launch" button on the success page (interactive installs
           only; suppressed under /quiet and /passive). The install location is fixed
           (no directory-selection UI), so the built-in [ProgramFiles64Folder] variable
           resolves it without a registry search. The ConfigTool's requireAdministrator
           manifest yields the expected UAC prompt when launched. -->
      <bal:WixStandardBootstrapperApplication Theme="hyperlinkLicense"
                                              LicenseUrl=""
                                              LogoFile="$(var.LogoFile)"
                                              SuppressOptionsUI="yes"
                                              LaunchTarget="[ProgramFiles64Folder]GraphMailer\GraphMailer.ConfigTool.exe"
                                              LaunchWorkingFolder="[ProgramFiles64Folder]GraphMailer" />
    </BootstrapperApplication>

    <!-- Skip the runtime install when ANY .NET 10 Desktop Runtime (x64) is already present —
         version-tolerant detection via the official .NET host probe (highest 10.x found, or empty).
         The previous check required the EXACT build-time version folder, so a machine that already
         had a usable older 10.0.x but not the latest reinstalled the shared runtime. Updating the
         shared runtime triggers Restart Manager, which interrupts other running .NET apps (e.g.
         PowerToys). A net10.0 app runs on any 10.0.x, so any 10.x suffices. -->
    <netfx:DotNetCoreSearch RuntimeType="desktop"
                            Platform="x64"
                            MajorVersion="10"
                            Variable="DotNet10DesktopVersion" />

    <Chain>
      <ExePackage Id="DotNetDesktopRuntime"
                  DisplayName=".NET Desktop Runtime $(var.DotNetVersion) (x64)"
                  SourceFile="$(var.DotNetRuntimeExe)"
                  DownloadUrl="$(var.DotNetRuntimeUrl)"
                  Compressed="no"
                  PerMachine="yes"
                  Permanent="yes"
                  Vital="yes"
                  DetectCondition="DotNet10DesktopVersion AND DotNet10DesktopVersion &gt;= v10.0.0"
                  InstallArguments="/install /quiet /norestart"
                  RepairArguments="/repair /quiet /norestart"
                  UninstallArguments="/uninstall /quiet /norestart" />

      <MsiPackage Id="GraphMailerMsi"
                  SourceFile="$(var.MsiPath)"
                  Vital="yes"
                  Visible="no" />
    </Chain>
  </Bundle>
</Wix>
